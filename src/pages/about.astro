---
import BaseLayout from "../layouts/BaseLayout.astro";

const timeline = [
  {
    year: "2005",
    title: "Primary School",
    place: "SK Seri Permai, Penang",
    desc: "six years in penang. made friends, lost erasers, somehow survived. didn't know what a computer was yet but i was already curious about everything. the pattern starts early.",
    tags: ["Early Life", "Penang"],
  },
  {
    year: "2011",
    title: "Penang Free School",
    place: "PFS, Penang",
    desc: "one of malaysia's oldest schools. walked in as a kid, left as someone who actually had direction. SPM came around — pulled 8As. more importantly: around 12-13, i discovered gaming and got obsessed with how people could connect virtually. that was the spark.",
    tags: ["Secondary School", "First Contact"],
  },
  {
    year: "2016",
    title: "Matriculation",
    place: "KMKT, Kelantan",
    desc: "packed my bags, moved to kelantan, and took my first real CS course. it was basic — very basic. but somewhere between the if-else blocks and the syntax errors, something clicked. i thought: yeah, i can see myself being happy doing this.",
    tags: ["Matriculation", "CS Begins"],
  },
  {
    year: "2017",
    title: "USM — Computer Science",
    place: "Universiti Sains Malaysia, Penang",
    desc: "enrolled in BSc Computer Science, majoring in AI, minoring in Management. things got serious. also joined ConvEx — one of USM's biggest annual events — as just a secretariat. that didn't last long.",
    tags: ["University", "AI", "USM"],
  },
  {
    year: "2019",
    title: "Project Director — ConvEx",
    place: "USM, Penang",
    desc: "got elected as project director of ConvEx (Convocation Expo), one of the largest student-run events at USM. suddenly responsible for 220+ students, a multi-million ringgit budget, and an entire event from A to Z. learned more about leadership, people, and pressure in that one year than anywhere else.",
    tags: ["Leadership", "Events", "220+ Team"],
  },
  {
    year: "2020",
    title: "First Real Program — FYP",
    place: "USM, Penang",
    desc: "built my first real project: Volunteer Task Allocation System — a full stack web app using Django, Python, PostgreSQL and AWS. used Fuzzy Theory to match volunteers to tasks intelligently. the moment i realised building something that actually solves a problem hits different.",
    tags: ["FYP", "Full Stack", "AI"],
  },
  {
    year: "2022",
    title: "ConvEx — The Comeback",
    place: "USM, Penang",
    desc: "post-covid, the university called me back to restart ConvEx after a 3-year hiatus. became the first ever two-time project director. started from absolute zero with a brand new team of 220+ students. rebuilt everything from scratch. said yes without thinking twice.",
    tags: ["Leadership", "ConvEx Returns", "2x Director"],
  },
  {
    year: "2023",
    title: "Masters — MSc Computer Science",
    place: "USM, Penang",
    desc: "went back for a masters — mixed mode. dissertation landed in AI + Cybersecurity: real-time DDoS attack detection in SDN environments using ensemble ML. Random Forest and AdaBoost ended up performing wild. also started part-time web3 work — technical support and community for an NFT company integrating blockchain for fashion brands.",
    tags: ["Masters", "AI", "Cybersecurity", "Web3"],
  },
  {
    year: "2024",
    title: "Masters Done",
    place: "USM → Wherever next",
    desc: "wrapped up the MSc. dissertation submitted, defended, done. not a student anymore — but honestly the learning never stopped. if anything it got faster. building more, experimenting more, thinking bigger.",
    tags: ["Graduation", "Milestone"],
  },
  {
    year: "Now",
    title: "Building & Exploring",
    place: "Penang / KL / The Internet",
    desc: "working on personal projects, doing volunteer blockchain education, and going deep on the AI × blockchain intersection. not chasing a title — just chasing the thing that's most interesting right now. if you're reading this — hi. we should probably talk.",
    tags: ["Present", "AI", "Blockchain", "Open to Collab"],
  },
];

const cards = [
  {
    id: "journey",
    icon: "fa-solid fa-route",
    tag: "origin story",
    title: "how i got here",
    preview: "in chronological order, because i respect your time.",
  },
  {
    id: "fun",
    icon: "fa-solid fa-gamepad",
    tag: "leisure",
    title: "things i do for fun",
    preview: "yes, i have a life outside of a code editor. allegedly.",
    body: [
      "beatboxing — yes, with my mouth. and also giving speeches and presentations. both to crowds of up to ~4000 people. it started as a random thing and somehow became a whole identity.",
      "going deep on whatever tech just dropped. reading docs, watching breakdowns, building tiny experiments — that's my version of relaxing.",
      "travelling between penang and KL so often it barely counts as travelling anymore. at this point KL is just my second bedroom.",
    ],
  },
  {
    id: "rabbit",
    icon: "fa-solid fa-bolt",
    tag: "obsessions",
    title: "current rabbit holes",
    preview: "whatever has fully consumed my brain this week.",
    body: [
      "the AI × blockchain intersection — specifically where these two worlds collide and what gets built there. i think the most interesting stuff happens at the edges.",
      "agentic AI systems — how far can you push autonomy before it gets weird? currently: further than most people think.",
      "real-world web3 adoption — not the hype, the actual infrastructure. how it moves from experimental to essential.",
    ],
  },
  {
    id: "tried",
    icon: "fa-solid fa-person-running",
    tag: "attempts",
    title: "things i've tried",
    preview: "some stuck. most didn't. all were worth it.",
    body: [
      "competitive beatboxing — entered several competitions. did not win a single one. zero regrets, would do it again immediately.",
      "directing a 220+ person student event. twice. the second time from absolute scratch post-covid. somehow both worked out.",
      "explaining my masters dissertation (DDoS detection in SDN using ensemble ML) to someone at a social event. they smiled and walked away. fair.",
    ],
  },
  {
    id: "facts",
    icon: "fa-solid fa-face-grin-stars",
    tag: "personality",
    title: "random facts about me",
    preview: "the stuff that doesn't fit anywhere else.",
    body: [
      "i hold the rare title of two-time project director of the same university event. was called back post-covid to restart it from zero. said yes before they finished the sentence.",
      "i genuinely believe adaptability > any specific skill. if something new exists, i want to understand it. sticking to old ways when better ones exist feels almost physically uncomfortable.",
      "i can beatbox, run a multi-million ringgit event, write an ML dissertation, and build a web app. the connecting thread is: got interested, got obsessed, figured it out.",
    ],
  },
  {
    id: "places",
    icon: "fa-solid fa-location-dot",
    tag: "life",
    title: "people & places",
    preview: "the humans and spots that actually shaped me.",
    body: [
      "penang — home base. the island has a way of keeping you grounded while also being completely chaotic. wouldn't trade it.",
      "kelantan (matriculation year) — the plot twist. moved there alone, took my first real CS course, and realized this was the direction. small chapter, big shift.",
      "the type of people i gravitate toward: curious ones. the kind who get genuinely excited about ideas and aren't afraid to say 'i don't know yet, but i'll figure it out'.",
    ],
  },
  {
    id: "chaos",
    icon: "fa-solid fa-fire",
    tag: "chaos",
    title: "the chaos log",
    preview: "a running list of things that happened. no context.",
    body: [
      "got a call from my university asking me to revive a major annual event that had been dead for 3 years. said yes. assembled a team of 220+ from scratch. it worked.",
      "performed beatbox and gave speeches in front of ~4000 people. adrenaline was immense. hands were shaking. the beat did not shake.",
      "went from 'i'll just check out web3 briefly' to doing technical support and community moderation for a blockchain company for 3 years. the brief check-out is still ongoing.",
    ],
  },
];
---

<BaseLayout title="Gosvindraj | About" hideFooter={true}>

  <!-- Section Nav removed — HTML preserved in style/script comments below -->

  <div id="about-layout">

  <!-- ── Intro ───────────────────────────────────── -->
  <section id="about-intro">

    <!-- default view: hi, i'm gosh -->
    <div id="intro-default">
      <div class="intro-inner">
        <p class="section-label" id="intro-label">about me</p>
        <h1 class="intro-heading" id="intro-heading">
          <span class="char-wrap"><span class="char-line">hi, i'm</span></span>
          <span class="char-wrap accent-word"><span class="char-line">gosh.</span></span>
        </h1>
        <div class="intro-bio" id="intro-bio">
          <p>
            i get obsessed with things quickly — AI, blockchain, whatever's next —
            and i build stuff to understand them better.
            most of it goes nowhere. some of it actually works.
            all of it teaches me something.
          </p>
          <p>
            click one of the <span style="font-family: monospace;">›</span> card to explore. or don't. your call.
          </p>
        </div>
      </div>
    </div>

    <!-- panel view: card content (swaps in on card select) -->
    <div id="intro-panel">

      <!-- journey panel (timeline) -->
      <div class="ep-content" data-panel="journey">
        <div class="ep-header">
          <span class="ep-tag">origin story</span>
          <h3 class="ep-title">how i got here</h3>
          <p class="ep-desc">in chronological order, because i respect your time</p>
        </div>
        <div class="tl-list">
          {timeline.map((entry, i) => (
            <div class="tl-row" data-tl-index={i}>
              <div class="tl-left-col">
                <span class="tl-year">{entry.year}</span>
                <div class="tl-vline"></div>
              </div>
              <div class="tl-card">
                <h4 class="tl-title">{entry.title}</h4>
                <p class="tl-place">{entry.place}</p>
                <p class="tl-desc">{entry.desc}</p>
                <div class="tl-tags">
                  {entry.tags.map(t => <span class="tl-tag">{t}</span>)}
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- all other panels -->
      {cards.filter(c => c.id !== "journey").map((c) => (
        <div class="ep-content" data-panel={c.id} style="display:none">
          <div class="ep-header">
            <span class="ep-tag">{c.tag}</span>
            <h3 class="ep-title">{c.title}</h3>
            <p class="ep-desc">{c.preview}</p>
          </div>
          <ul class="ep-list">
            {(c.body ?? []).map(item => (
              <li class="ep-item">
                <span class="ep-bullet">—</span>
                <span>{item}</span>
              </li>
            ))}
          </ul>
        </div>
      ))}

    </div><!-- /intro-panel -->

  </section>

  <!-- ── Explore ─────────────────────────────────── -->
  <section id="about-explore">

    <!-- selector cards -->
    <div class="explore-cards" id="explore-cards">
      <div class="ec-center-hint" id="ec-center-hint">
        <span class="ec-center-ring"></span>
        <span class="ec-center-text">pick<br/>one</span>
      </div>
      {cards.map((c) => (
        <div class="ec-card-wrap">
          <button class="ec-card" data-card={c.id} aria-label={c.title}>
            <div class="ec-icon">
              <i class={c.icon}></i>
            </div>
            <div class="ec-meta">
              <span class="ec-tag">{c.tag}</span>
            </div>
          </button>
        </div>
      ))}
    </div>

  </section>

  </div><!-- /about-layout -->

</BaseLayout>

<style>
  /* ── Shared ──────────────────────────────────── */
  .section-label {
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--accent);
    opacity: 0;
  }

  /* ── Intro section ───────────────────────────── */
  #about-intro {
    /* base: just a container; children handle layout */
  }

  #intro-default {
    min-height: calc(100vh - var(--nav-height));
    display: flex;
    align-items: center;
    padding: 5rem 8%;
  }

  /* panel view: hidden until card selected */
  #intro-panel {
    display: none;
  }

  .intro-inner {
    max-width: 780px;
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  .intro-heading {
    font-family: "Cormorant Garamond", serif;
    font-size: clamp(3rem, 7vw, 6rem);
    font-weight: 300;
    color: var(--text);
    line-height: 1.1;
    letter-spacing: 0.02em;
    display: flex;
    flex-direction: column;
    gap: 0.1em;
  }

  .char-wrap  { display: block; overflow: hidden; }
  .char-line  { display: block; transform: translateY(110%); }
  .accent-word .char-line { color: var(--accent); }

  .intro-bio {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    opacity: 0;
  }

  .intro-bio p {
    font-size: clamp(0.95rem, 1.8vw, 1.1rem);
    font-weight: 400;
    color: var(--muted);
    line-height: 1.85;
    max-width: 620px;
  }

  /* ── Explore section ─────────────────────────── */
  #about-explore {
    padding: 4rem 8% 3rem;
  }

  /* ── Card circle ─────────────────────────────── */
  /*   Positions managed by GSAP — no nth-child rules */
  .explore-cards {
    position: relative;
    min-height: 500px;
    margin-bottom: 0;
    overflow: visible;
  }

  /* ── Orbit centre hint ───────────────────────── */
  .ec-center-hint {
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    display: flex;
    align-items: center;
    justify-content: center;
    width: 76px;
    height: 76px;
    pointer-events: none;
    z-index: 2;
  }

  .ec-center-ring {
    position: absolute;
    inset: 0;
    border-radius: 50%;
    border: 1px solid rgba(155, 109, 206, 0.25);
    animation: ec-ring-pulse 3s ease-in-out infinite;
  }

  @keyframes ec-ring-pulse {
    0%, 100% { transform: scale(1);    opacity: 0.5; }
    50%       { transform: scale(1.12); opacity: 1;   }
  }

  .ec-center-text {
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--accent);
    opacity: 0.55;
    text-align: center;
    line-height: 1.5;
  }

  @media (max-width: 900px) {
    .ec-center-hint { display: none; }
  }

  .ec-card-wrap {
    position: absolute;
    width: 145px;
    left: 50%;
    top: 50%;
  }

  .ec-card {
    width: 100%;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 0.9rem 1rem;
    display: flex;
    align-items: center;
    gap: 0.6rem;
    cursor: none;
    text-align: left;
    box-shadow: 0 3px 14px rgba(0, 0, 0, 0.45);
    transition: background var(--transition), border-color var(--transition),
                box-shadow var(--transition);
    opacity: 0;
    position: relative;
  }

  .ec-card::before {
    content: '';
    position: absolute;
    left: 0; top: 0; bottom: 0;
    width: 2px;
    border-radius: 4px 0 0 4px;
    background: var(--accent);
    transform: scaleY(0);
    transform-origin: bottom;
    transition: transform 0.25s ease;
  }

  .ec-card:hover {
    background: var(--surface);
    border-color: var(--border-hover);
    box-shadow: 0 8px 28px rgba(0, 0, 0, 0.55);
  }
  .ec-card.active {
    background: var(--surface);
    border-color: var(--accent);
    box-shadow: 0 4px 20px rgba(155, 109, 206, 0.18);
  }
  .ec-card.active::before { transform: scaleY(1); }

  .ec-icon {
    width: 30px;
    height: 30px;
    border: 1px solid var(--border);
    border-radius: 3px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--accent);
    font-size: 12px;
    flex-shrink: 0;
    transition: border-color var(--transition), background var(--transition);
  }

  .ec-card:hover .ec-icon,
  .ec-card.active .ec-icon {
    border-color: var(--border-hover);
    background: var(--accent-dim);
  }

  .ec-meta {
    flex: 1;
    display: flex;
    align-items: center;
    min-width: 0;
  }

  .ec-tag {
    font-size: 9px;
    font-weight: 500;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--accent);
    opacity: 0.7;
  }

  .ec-title {
    font-size: 0.85rem;
    font-weight: 400;
    color: var(--text);
    letter-spacing: 0.01em;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }


  /* ── Intro panel (left-column card content) ─── */
  #intro-panel {
    flex-direction: column;
  }

  /* ── Custom scrollbar for left column ───────── */
  #about-intro {
    scrollbar-width: thin;
    scrollbar-color: rgba(155, 109, 206, 0.25) transparent;
  }

  #about-intro::-webkit-scrollbar {
    width: 3px;
  }

  #about-intro::-webkit-scrollbar-track {
    background: transparent;
  }

  #about-intro::-webkit-scrollbar-thumb {
    background: rgba(155, 109, 206, 0.25);
    border-radius: 2px;
  }

  #about-intro::-webkit-scrollbar-thumb:hover {
    background: rgba(155, 109, 206, 0.55);
  }

  .ep-content {
    padding: 2.5rem;
  }

  .ep-header {
    margin-bottom: 2rem;
    padding-bottom: 1.25rem;
    border-bottom: 1px solid var(--border);
  }

  .ep-tag {
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--accent);
    display: block;
    margin-bottom: 0.4rem;
  }

  .ep-title {
    font-family: "Cormorant Garamond", serif;
    font-size: clamp(1.5rem, 3vw, 2.2rem);
    font-weight: 300;
    color: var(--text);
    letter-spacing: 0.03em;
    margin-bottom: 0.35rem;
  }

  .ep-desc {
    font-size: 0.82rem;
    color: var(--muted);
    line-height: 1.7;
    font-style: italic;
  }

  /* generic list panel */
  .ep-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .ep-item {
    display: flex;
    gap: 0.75rem;
    font-size: 0.85rem;
    color: var(--muted);
    line-height: 1.7;
  }

  .ep-bullet {
    color: var(--accent);
    flex-shrink: 0;
    font-weight: 600;
  }

  /* ── Timeline inside panel ───────────────────── */
  .tl-list {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .tl-row {
    display: flex;
    gap: 1.5rem;
    align-items: stretch;
  }

  .tl-left-col {
    display: flex;
    flex-direction: column;
    align-items: center;
    flex-shrink: 0;
    width: 48px;
  }

  .tl-year {
    font-family: "Courier New", monospace;
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.14em;
    color: var(--accent);
    white-space: nowrap;
    padding-top: 0.1rem;
    text-align: center;
  }

  .tl-vline {
    width: 1px;
    flex: 1;
    background: var(--border);
    margin-top: 0.5rem;
    min-height: 1.5rem;
  }

  .tl-row:last-child .tl-vline { display: none; }

  .tl-card {
    flex: 1;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 1.1rem 1.25rem;
    margin-bottom: 1rem;
    transition: border-color var(--transition), background var(--transition);
  }

  .tl-card:hover {
    border-color: var(--border-hover);
    background: rgba(155,109,206,0.03);
  }

  .tl-title {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--text);
    margin-bottom: 0.2rem;
    letter-spacing: 0.01em;
  }

  .tl-place {
    font-size: 11px;
    color: var(--muted);
    letter-spacing: 0.07em;
    margin-bottom: 0.6rem;
    font-style: italic;
  }

  .tl-desc {
    font-size: 0.8rem;
    color: var(--muted);
    line-height: 1.75;
    margin-bottom: 0.85rem;
  }

  .tl-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
  }

  .tl-tag {
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--accent);
    background: var(--accent-dim);
    border: 1px solid rgba(155,109,206,0.2);
    padding: 0.15rem 0.5rem;
    border-radius: 2px;
  }

  /* ── Section Nav (removed — kept for reference) ─────────────────────
  HTML:
    <nav id="about-nav" aria-label="Page sections">
      <div id="about-nav-track"><div id="about-nav-pill"></div></div>
      <button class="anav-btn" data-target="about-intro"   data-index="0" aria-label="intro">
        <span class="anav-dot"></span><span class="anav-label">intro</span>
      </button>
      <button class="anav-btn" data-target="about-explore" data-index="1" aria-label="explore">
        <span class="anav-dot"></span><span class="anav-label">explore</span>
      </button>
    </nav>

  #about-nav {
    position: fixed; right: 2rem; top: 50%; transform: translateY(-50%);
    z-index: 50; display: flex; flex-direction: column;
    align-items: center; gap: 1.8rem; opacity: 0;
  }
  #about-nav-track {
    position: absolute; left: 50%; top: 0; bottom: 0; width: 1px;
    transform: translateX(-50%); background: rgba(255,255,255,0.06);
    pointer-events: none;
  }
  #about-nav-pill {
    position: absolute; left: 50%; transform: translateX(-50%);
    width: 1px; height: 14px; top: 0; will-change: top; filter: blur(0.3px);
    background: linear-gradient(to bottom, transparent, var(--accent), transparent);
  }
  .anav-btn {
    position: relative; display: flex; align-items: center;
    background: none; border: none; cursor: none; padding: 3px; z-index: 1;
  }
  .anav-label {
    position: absolute; right: calc(100% + 0.7rem); font-size: 10px;
    font-weight: 500; letter-spacing: 0.15em; text-transform: uppercase;
    color: var(--muted); opacity: 0.22; white-space: nowrap; pointer-events: none;
    transition: opacity 0.25s ease, color 0.25s ease, transform 0.25s ease;
    transform: translateX(4px);
  }
  .anav-dot {
    width: 5px; height: 5px; border-radius: 50%; background: rgba(155,109,206,0.3);
    flex-shrink: 0; display: block;
    transition: background 0.25s ease, transform 0.25s ease, box-shadow 0.25s ease;
  }
  .anav-btn.active .anav-dot { background: var(--accent); transform: scale(1.5); box-shadow: 0 0 6px rgba(155,109,206,0.7); }
  .anav-btn.active .anav-label { opacity: 0.7; color: var(--text); }
  #about-nav:hover .anav-label { opacity: 0.9; transform: translateX(0); }
  #about-nav:hover .anav-btn.active .anav-label { opacity: 1; color: var(--text); }
  #about-nav:hover .anav-dot { background: rgba(155,109,206,0.55); }
  #about-nav:hover .anav-btn.active .anav-dot { background: var(--accent); }
  ── end Section Nav ── */

  /* ── Two-column desktop layout ──────────────── */
  @media (min-width: 701px) {
    #about-layout {
      display: grid;
      grid-template-columns: 1fr 1fr;
      align-items: start;
    }

    /* left col: fixed height, scrollable when panel content is long */
    #about-intro {
      overflow-y: auto;
      height: calc(100vh - var(--nav-height));
      min-height: unset;
      position: sticky;
      top: var(--nav-height);
    }

    /* default view fills the column height and centres content */
    #intro-default {
      height: 100%;
      min-height: unset;
      padding: 5rem 3rem 5rem 8%;
    }

    .intro-inner { max-width: 100%; }

    /* panel view: fills column */
    #intro-panel {
      min-height: 100%;
    }

    .ep-content {
      padding: 2.5rem 3rem 2.5rem 8%;
    }

    /* right col: orbit, vertically centred */
    #about-explore {
      padding: 2rem 8% 2rem 3.5rem;
      border-left: 1px solid var(--border);
      display: flex;
      align-items: center;
      min-height: calc(100vh - var(--nav-height));
    }

    .explore-cards { width: 100%; }

  }

  /* ── Mobile ──────────────────────────────────── */
  @media (max-width: 700px) {
    #intro-default { padding: 4rem 6%; min-height: unset; }
    #about-explore { padding: 4rem 6% 2rem; }
    /* #about-nav  { display: none; } */
    .explore-cards { position: static; min-height: unset; display: flex; flex-direction: column; gap: 0.75rem; }
    .ec-card-wrap  { position: static; width: auto; transform: none !important; }
    .ec-card       { opacity: 1; transform: none !important; }
    .ep-content    { padding: 1.5rem; }
    .tl-left-col   { width: 38px; }
  }
</style>

<script>
  import gsap from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  import { ScrollToPlugin }  from "gsap/ScrollToPlugin";
  gsap.registerPlugin(ScrollTrigger, ScrollToPlugin);

  /* ── Glitch reveal ───────────────────────────── */
  const GLITCH = "!<>-_\\/[]{}—=+*^?#@$%&";

  function glitchReveal(el: HTMLElement, finalText: string, duration = 780) {
    const frames = 18;
    const ms = Math.round(duration / frames);
    let frame = 0;
    el.style.opacity = "1";

    const iv = setInterval(() => {
      const progress = frame / frames;
      const revealed = Math.floor(progress * finalText.length);
      let display = "";
      for (let i = 0; i < finalText.length; i++) {
        if (i < revealed) {
          display += Math.random() < 0.07 * (1 - progress)
            ? GLITCH[Math.floor(Math.random() * GLITCH.length)]
            : finalText[i];
        } else {
          display += finalText[i] === " " ? "\u00a0"
            : GLITCH[Math.floor(Math.random() * GLITCH.length)];
        }
      }
      el.textContent = display;
      if (frame < frames - 2 && Math.random() < 0.4) {
        el.style.textShadow = `${+(Math.random()*4-2).toFixed(1)}px 0 rgba(255,0,200,0.6),`
                            + `${+(Math.random()*-4+2).toFixed(1)}px 0 rgba(0,255,255,0.6)`;
      } else {
        el.style.textShadow = "";
      }
      frame++;
      if (frame > frames) {
        clearInterval(iv);
        el.textContent = finalText;
        el.style.textShadow = "";
      }
    }, ms);
  }

  /* ── Intro animations ────────────────────────── */
  function initAbout() {
    const label = document.getElementById("intro-label");
    if (!label) return;

    // Intro section is always above-fold — animate directly, no ScrollTrigger
    gsap.to(label, { opacity: 1, duration: 0.5, ease: "power3.out", delay: 0.2 });

    const lines     = Array.from(document.querySelectorAll<HTMLElement>(".char-line"));
    const lineTexts = lines.map(el => el.textContent ?? "");
    lines.forEach((el, i) => {
      setTimeout(() => {
        gsap.set(el, { y: "0%" });
        glitchReveal(el, lineTexts[i], 780);
      }, 300 + i * 200);
    });

    const bio = document.getElementById("intro-bio");
    if (bio) {
      const paras = bio.querySelectorAll("p");
      gsap.timeline({ delay: 0.65 })
        .to(bio, { opacity: 1, duration: 0.01 })
        .fromTo(paras,
          { opacity: 0, y: 18 },
          { opacity: 1, y: 0, duration: 0.6, stagger: 0.15, ease: "power3.out" }
        );
    }
  }

  /* ── Explore section ─────────────────────────── */
  function initExplore() {
    const ecCards     = Array.from(document.querySelectorAll<HTMLElement>(".ec-card"));
    const ecWraps     = Array.from(document.querySelectorAll<HTMLElement>(".ec-card-wrap"));
    const introDefault = document.getElementById("intro-default")!;
    const introPanel   = document.getElementById("intro-panel")!;
    if (!ecCards.length || !introPanel) return;

    /* ── Constants ──────────────────────────────── */
    const N      = ecWraps.length;      // 7
    const RX     = 205, RY = 140;       // ellipse radii
    const HALF_W = 73;                  // half of 145px card width
    const HALF_H = 30;                  // approx half card height
    const ROTATIONS = [-2.5, 1.8, -1.2, 2.8, -2, 1.5, -3];

    const CENTER  = { x: -HALF_W, y: -HALF_H };

    /* ── Continuous orbit ticker ────────────────── */
    let orbitDeg     = -90;                      // leading angle in degrees (starts at top)
    const DEG_PER_MS = 360 / (30 * 1000);        // one full revolution per 30 s
    let lastTick     = performance.now();
    const returningSet = new Set<number>();       // cards mid-transition, skip ticker
    let orbitingCards  = Array.from({ length: N }, (_, i) => i); // indices of orbiting cards

    function slotPos(slotIdx: number, total: number, deg: number) {
      const rad = ((deg + (slotIdx / total) * 360) * Math.PI) / 180;
      return { x: RX * Math.cos(rad) - HALF_W, y: RY * Math.sin(rad) - HALF_H };
    }

    // Smoothly redistribute orbiting cards to their new evenly-spaced slots
    function redistributeOrbit(dur = 0.55) {
      const n = orbitingCards.length;
      const ahead = orbitDeg + DEG_PER_MS * dur * 1000; // anticipate where orbit will be
      orbitingCards.forEach((cardIdx, slotIdx) => {
        returningSet.add(cardIdx);
        const { x, y } = slotPos(slotIdx, n, ahead);
        gsap.to(ecWraps[cardIdx], {
          x, y, duration: dur, ease: "power3.inOut",
          onComplete: () => returningSet.delete(cardIdx),
        });
      });
    }

    function orbitTick() {
      const now = performance.now();
      orbitDeg += DEG_PER_MS * (now - lastTick);
      lastTick = now;
      const n = orbitingCards.length;
      orbitingCards.forEach((cardIdx, slotIdx) => {
        if (returningSet.has(cardIdx)) return;
        const { x, y } = slotPos(slotIdx, n, orbitDeg);
        gsap.set(ecWraps[cardIdx], { x, y });
      });
    }
    gsap.ticker.add(orbitTick);

    /* ── Mobile: simple reveal + click, skip orbit ─ */
    if (window.matchMedia("(max-width: 700px)").matches) {
      introPanel.style.display = "none";
      let mobPanelOpen = false, mobActiveId = "";
      ScrollTrigger.create({
        trigger: "#explore-cards", start: "top 85%", once: true,
        onEnter: () => gsap.to(ecCards, { opacity: 1, duration: 0.5, stagger: 0.08, ease: "power3.out" }),
      });

      function mobClosePanel() {
        gsap.to(introPanel, { opacity: 0, duration: 0.2, ease: "power2.in", onComplete: () => {
          introPanel.style.display = "none";
          introDefault.style.display = "";
          gsap.fromTo(introDefault, { opacity: 0 }, { opacity: 1, duration: 0.35, ease: "power3.out" });
          ecCards.forEach(c => c.classList.remove("active"));
          mobPanelOpen = false; mobActiveId = "";
        }});
      }

      ecCards.forEach((card, i) => {
        card.addEventListener("click", () => {
          const id = card.dataset.card; if (!id) return;
          // tap active card again → close panel
          if (mobPanelOpen && id === mobActiveId) { mobClosePanel(); return; }
          ecCards.forEach(c => c.classList.toggle("active", c === card));
          if (!mobPanelOpen) {
            introPanel.querySelectorAll<HTMLElement>(".ep-content").forEach(el => (el.style.display = "none"));
            const first = introPanel.querySelector<HTMLElement>(`[data-panel="${id}"]`);
            if (first) first.style.display = "block";
            introDefault.style.display = "none";
            introPanel.style.display = "flex";
            gsap.fromTo(introPanel, { opacity: 0 }, { opacity: 1, duration: 0.4, ease: "power3.out" });
            mobPanelOpen = true; mobActiveId = id;
          } else {
            const cur = introPanel.querySelector<HTMLElement>(`[data-panel="${mobActiveId}"]`);
            const nxt = introPanel.querySelector<HTMLElement>(`[data-panel="${id}"]`);
            if (cur && nxt) {
              gsap.to(cur, { opacity: 0, duration: 0.15, onComplete: () => { cur.style.display = "none"; nxt.style.display = "block"; gsap.to(nxt, { opacity: 1, duration: 0.3 }); } });
            }
            mobActiveId = id;
          }
          gsap.to(window, { scrollTo: { y: 0 }, duration: 0.6, ease: "power3.inOut" });
        });
      });
      return;
    }

    /* ── Desktop: orbit placement ───────────────── */
    ecWraps.forEach((wrap, i) => {
      const { x, y } = slotPos(i, N, orbitDeg);
      gsap.set(wrap, { x, y });
      gsap.set(ecCards[i], { opacity: 0, rotation: ROTATIONS[i] });
    });
    introPanel.style.display = "none";

    // Fade cards in — orbit ticker already running
    gsap.to(ecCards, {
      opacity: 1, duration: 0.5, delay: 0.3,
      stagger: { amount: 0.45, from: "start" },
      ease: "power3.out",
    });

    /* ── Hover: scale up while orbiting ────────── */
    ecCards.forEach((card, i) => {
      card.addEventListener("mouseenter", () => {
        if (i === centerIdx) return;
        gsap.to(card, { scale: 1.1, duration: 0.15, ease: "power3.out" });
      });
      card.addEventListener("mouseleave", () => {
        if (i === centerIdx) return;
        gsap.to(card, { scale: 1, duration: 0.2, ease: "power3.in" });
      });
    });

    /* ── Panel helpers ──────────────────────────── */
    let panelOpen = false;
    let activeId  = "";

    function animateTimelineIn() {
      gsap.fromTo(introPanel.querySelectorAll<HTMLElement>(".tl-row"),
        { opacity: 0, x: -18 },
        { opacity: 1, x: 0, duration: 0.45, stagger: 0.07, ease: "power3.out", delay: 0.1 }
      );
    }
    function animateListIn() {
      gsap.fromTo(introPanel.querySelectorAll<HTMLElement>(".ep-item"),
        { opacity: 0, x: -14 },
        { opacity: 1, x: 0, duration: 0.4, stagger: 0.08, ease: "power3.out", delay: 0.1 }
      );
    }

    function openPanel(cardId: string) {
      const next = introPanel.querySelector<HTMLElement>(`[data-panel="${cardId}"]`);
      if (!next) return;

      if (!panelOpen) {
        introPanel.querySelectorAll<HTMLElement>(".ep-content").forEach(el => (el.style.display = "none"));
        next.style.display = "block";
        // pre-hide panel and its animated children BEFORE it becomes visible
        gsap.set(introPanel, { opacity: 0 });
        if (cardId === "journey") {
          gsap.set(introPanel.querySelectorAll(".tl-row"), { opacity: 0, x: -18 });
        } else {
          gsap.set(introPanel.querySelectorAll(".ep-item"), { opacity: 0, x: -14 });
        }
        // swap intro default → panel view
        gsap.to(introDefault, { opacity: 0, duration: 0.2, ease: "power2.in",
          onComplete: () => {
            introDefault.style.display = "none";
            introPanel.style.display = "flex";
            document.getElementById("about-intro")?.scrollTo({ top: 0, behavior: "instant" });
            gsap.to(introPanel, {
              opacity: 1, duration: 0.35, ease: "power3.out",
              onComplete: () => { if (cardId === "journey") animateTimelineIn(); else animateListIn(); },
            });
          },
        });
        panelOpen = true;
        activeId  = cardId;
        return;
      }

      if (cardId === activeId) return;

      const current = introPanel.querySelector<HTMLElement>(`[data-panel="${activeId}"]`);
      activeId = cardId;
      // scroll left column to top when switching panels
      document.getElementById("about-intro")?.scrollTo({ top: 0, behavior: "smooth" });
      if (current) {
        gsap.to(current, {
          opacity: 0, y: -10, duration: 0.2, ease: "power2.in",
          onComplete: () => {
            current.style.display = "none";
            next.style.display = "block";
            gsap.fromTo(next, { opacity: 0, y: 12 }, {
              opacity: 1, y: 0, duration: 0.35, ease: "power3.out",
              onComplete: () => { if (cardId === "journey") animateTimelineIn(); else animateListIn(); },
            });
          },
        });
      }
    }

    /* ── Center-swap logic ──────────────────────── */
    let centerIdx = -1;

    function selectCard(clickedIdx: number) {
      if (clickedIdx === centerIdx) { resetToOrbit(); return; }

      const prevCenter = centerIdx;
      centerIdx = clickedIdx;

      ecCards.forEach((c, i) => c.classList.toggle("active", i === clickedIdx));
      gsap.to("#ec-center-hint", { opacity: 0, scale: 0.8, duration: 0.3, ease: "power2.in" });

      /* pull selected card to center */
      returningSet.add(clickedIdx);
      gsap.to(ecWraps[clickedIdx], {
        x: CENTER.x, y: CENTER.y, duration: 0.55, ease: "power3.inOut",
        onComplete: () => returningSet.delete(clickedIdx),
      });
      gsap.to(ecCards[clickedIdx], { rotation: 0, scale: 1.1, duration: 0.55, ease: "power3.inOut" });

      /* rebuild orbiting list: remove clicked, re-add previous center if any */
      orbitingCards = orbitingCards.filter(idx => idx !== clickedIdx);
      if (prevCenter !== -1 && !orbitingCards.includes(prevCenter)) {
        orbitingCards.push(prevCenter);
        gsap.to(ecCards[prevCenter], { rotation: ROTATIONS[prevCenter], scale: 1, duration: 0.55, ease: "power3.inOut" });
      }

      /* re-space remaining cards evenly */
      redistributeOrbit(0.55);

      const cardId = ecCards[clickedIdx].dataset.card;
      if (cardId) openPanel(cardId);
    }

    ecCards.forEach((card, i) => card.addEventListener("click", () => selectCard(i)));

    /* ── Reset: return center card to orbit ─────── */
    function resetToOrbit() {
      if (centerIdx === -1) return;
      const prev = centerIdx;
      centerIdx = -1;

      ecCards.forEach(c => c.classList.remove("active"));
      gsap.to(ecCards[prev], { rotation: ROTATIONS[prev], scale: 1, duration: 0.55, ease: "power3.inOut" });

      /* add back and re-space all 7 evenly */
      if (!orbitingCards.includes(prev)) orbitingCards.push(prev);
      redistributeOrbit(0.55);

      gsap.to("#ec-center-hint", { opacity: 1, scale: 1, duration: 0.4, ease: "power2.out", delay: 0.25 });

      if (panelOpen) {
        gsap.to(introPanel, { opacity: 0, duration: 0.25, ease: "power2.in",
          onComplete: () => {
            introPanel.style.display = "none";
            introDefault.style.display = "";
            gsap.fromTo(introDefault, { opacity: 0 }, { opacity: 1, duration: 0.35, ease: "power3.out" });
          },
        });
        panelOpen = false;
        activeId = "";
      }
    }

    document.getElementById("about-explore")?.addEventListener("click", (e) => {
      if (centerIdx === -1) return;
      if ((e.target as HTMLElement).closest(".ec-card")) return;
      resetToOrbit();
    });

  }

  /* ── Section Nav (removed — kept for reference) ─────────────────────
  function initAboutNav() {
    const nav  = document.getElementById("about-nav");
    const pill = document.getElementById("about-nav-pill");
    const btns = Array.from(document.querySelectorAll<HTMLElement>(".anav-btn"));
    if (!nav || !pill || !btns.length) return;

    const sections = btns.map(b => document.getElementById(b.dataset.target!)!);

    gsap.to(nav, { opacity: 1, duration: 0.6, delay: 0.8, ease: "power2.out" });

    function setPill(i: number) {
      const navRect = nav.getBoundingClientRect();
      const btnRect = btns[i].getBoundingClientRect();
      const cy = btnRect.top + btnRect.height / 2 - navRect.top;
      gsap.to(pill, { top: cy - 7, duration: 0.45, ease: "power3.inOut" });
    }

    function setActive(i: number) {
      btns.forEach((b, j) => b.classList.toggle("active", j === i));
      setPill(i);
    }

    let scrolling = false;
    const observer = new IntersectionObserver(
      (entries) => {
        if (scrolling) return;
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            const i = sections.indexOf(entry.target as HTMLElement);
            if (i !== -1) setActive(i);
          }
        });
      },
      { threshold: 0.3 }
    );
    sections.forEach(s => s && observer.observe(s));

    requestAnimationFrame(() => setPill(0));
    setActive(0);

    btns.forEach((btn, i) => {
      btn.addEventListener("click", () => {
        const target = sections[i];
        if (!target) return;
        scrolling = true;
        setActive(i);
        const navH = parseInt(getComputedStyle(document.documentElement).getPropertyValue("--nav-height") || "72");
        gsap.to(window, {
          scrollTo: target.getBoundingClientRect().top + window.scrollY - navH - 24,
          duration: 0.9,
          ease: "power3.inOut",
          onComplete: () => { scrolling = false; },
        });
        // glitch flash on heading
        const heading = target.querySelector<HTMLElement>("h1, h2");
        if (heading) {
          const orig = heading.textContent ?? "";
          const G = "!<>-_\\/[]{}—=+*^?#@$%&";
          let f = 0;
          const iv = setInterval(() => {
            heading.textContent = orig.split("").map(c =>
              c === " " ? " " : Math.random() < 0.45 ? G[Math.floor(Math.random()*G.length)] : c
            ).join("");
            heading.style.textShadow = Math.random() < 0.5
              ? `${(Math.random()*3-1.5).toFixed(1)}px 0 rgba(255,0,200,0.55),${(Math.random()*-3+1.5).toFixed(1)}px 0 rgba(0,255,255,0.55)`
              : "";
            if (++f > 7) {
              clearInterval(iv);
              heading.textContent = orig;
              heading.style.textShadow = "";
            }
          }, 55);
        }
      });
    });

    return () => observer.disconnect();
  }
  ── end Section Nav ── */

  document.addEventListener("astro:page-load", initAbout);
  document.addEventListener("astro:page-load", initExplore);
  // document.addEventListener("astro:page-load", initAboutNav);
</script>
