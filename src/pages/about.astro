---
import BaseLayout from "../layouts/BaseLayout.astro";

const timeline = [
  {
    year: "2013",
    title: "Primary School",
    place: "SK Placeholder Jaya, Kuala Lumpur",
    desc: "survived 6 years of primary school. made some friends, lost some erasers, and learned that sitting still is genuinely hard. got the certificate anyway.",
    tags: ["Early Life", "KL"],
  },
  {
    year: "2019",
    title: "Secondary School Begins",
    place: "SMK Placeholder Indah, Selangor",
    desc: "entered secondary school with zero plan. somehow stumbled into the computer lab and thought 'yeah, this thing is kinda cool actually'. first contact with tech. the obsession started quietly.",
    tags: ["Education", "First Contact"],
  },
  {
    year: "2021",
    title: "The Tech Spark",
    place: "Bedroom, 2am",
    desc: "wrote my first real program. it did basically nothing useful — printed some numbers, looped a few times. but i felt like an absolute genius for three whole days. that feeling never really left.",
    tags: ["Coding", "Milestone"],
  },
  {
    year: "2022",
    title: "SPM & The Big Decision",
    place: "SMK Placeholder Indah, Selangor",
    desc: "sat through the most important exam of my life. survived. immediately started spiralling about what's next. spoiler: went all in on tech. no regrets (yet).",
    tags: ["SPM", "Turning Point"],
  },
  {
    year: "2023",
    title: "First Real Projects",
    place: "GitHub, mostly",
    desc: "shipped the first things i was actually semi-proud of. a snake game and a crypto price tracker. don't judge the scope — judge the energy. 40+ stackoverflow tabs open at all times.",
    tags: ["Projects", "Building"],
  },
  {
    year: "2024",
    title: "University Life",
    place: "Universiti Placeholder Malaysia",
    desc: "enrolled in uni, pursuing CS. learning a lot. breaking things professionally now instead of just accidentally. realised college coffee is the only consistent thing in my life.",
    tags: ["University", "CS"],
  },
  {
    year: "Now",
    title: "Actively Building",
    place: "Wherever there's wifi",
    desc: "exploring big ideas, shipping small things, and slowly working on the stuff that doesn't exist yet. if you're reading this — hi, we should probably talk.",
    tags: ["Present", "Open to Collab"],
  },
];

const cards = [
  {
    id: "journey",
    icon: "fa-solid fa-route",
    tag: "origin story",
    title: "how i got here",
    preview: "in chronological order, because i respect your time.",
  },
  {
    id: "fun",
    icon: "fa-solid fa-gamepad",
    tag: "leisure",
    title: "things i do for fun",
    preview: "yes, i have a life outside of a code editor. allegedly.",
    body: [
      "placeholder — something about gaming / binge-watching / going outside occasionally",
      "placeholder — a hobby you picked up and either stuck with or abandoned in 3 days",
      "placeholder — the one thing you do to decompress that nobody expects",
    ],
  },
  {
    id: "rabbit",
    icon: "fa-solid fa-bolt",
    tag: "obsessions",
    title: "current rabbit holes",
    preview: "whatever has fully consumed my brain this week.",
    body: [
      "placeholder — the topic you've been reading about at 2am",
      "placeholder — the youtube channel / podcast / subreddit you can't stop",
      "placeholder — the thing you told yourself was 'just a quick look'",
    ],
  },
  {
    id: "tried",
    icon: "fa-solid fa-person-running",
    tag: "attempts",
    title: "things i've tried",
    preview: "some stuck. most didn't. all were worth it.",
    body: [
      "placeholder — a sport or physical thing you gave a shot",
      "placeholder — a creative skill you picked up (music? art? cooking?)",
      "placeholder — the most random thing you've ever attempted for no reason",
    ],
  },
  {
    id: "facts",
    icon: "fa-solid fa-face-grin-stars",
    tag: "personality",
    title: "random facts about me",
    preview: "the stuff that doesn't fit anywhere else.",
    body: [
      "placeholder — an unpopular opinion you hold firmly",
      "placeholder — something weird/quirky about how you think or operate",
      "placeholder — the most 'very you' thing someone could say about you",
    ],
  },
  {
    id: "places",
    icon: "fa-solid fa-location-dot",
    tag: "life",
    title: "people & places",
    preview: "the humans and spots that actually shaped me.",
    body: [
      "placeholder — somewhere you've been that left an impression",
      "placeholder — the type of people you gravitate toward",
      "placeholder — a place you want to go / person you want to become",
    ],
  },
  {
    id: "chaos",
    icon: "fa-solid fa-fire",
    tag: "chaos",
    title: "the chaos log",
    preview: "a running list of things that happened. no context.",
    body: [
      "placeholder — a spontaneous decision that actually worked out",
      "placeholder — something that went completely sideways and you're still recovering",
      "placeholder — the most unhinged thing you've done on a tuesday",
    ],
  },
];
---

<BaseLayout title="Gosvindraj | About">

  <!-- Section Nav removed — HTML preserved in style/script comments below -->

  <div id="about-layout">

  <!-- ── Intro ───────────────────────────────────── -->
  <section id="about-intro">
    <div class="intro-inner">
      <p class="section-label" id="intro-label">about me</p>
      <h1 class="intro-heading" id="intro-heading">
        <span class="char-wrap"><span class="char-line">hi, i'm</span></span>
        <span class="char-wrap accent-word"><span class="char-line">gosh.</span></span>
      </h1>
      <div class="intro-bio" id="intro-bio">
        <p>
          i get obsessed with things quickly — AI, blockchain, whatever's next —
          and i build stuff to understand them better.
          most of it goes nowhere. some of it actually works.
          all of it teaches me something.
        </p>
        <p>
          click one of the <span style="font-family: monospace;">›</span> card to explore. or don't. your call.
        </p>
      </div>
    </div>
  </section>

  <!-- ── Explore ─────────────────────────────────── -->
  <section id="about-explore">

    <!-- selector cards -->
    <div class="explore-cards" id="explore-cards">
      {cards.map((c) => (
        <div class="ec-card-wrap">
          <button class="ec-card" data-card={c.id} aria-label={c.title}>
            <div class="ec-icon">
              <i class={c.icon}></i>
            </div>
            <div class="ec-meta">
              <span class="ec-tag">{c.tag}</span>
              <span class="ec-title">{c.title}</span>
            </div>
            <i class="fa-solid fa-arrow-right ec-arrow"></i>
          </button>
        </div>
      ))}
    </div>

  </section>

  </div><!-- /about-layout -->

  <!-- ── Expansion panel (full-width, below layout) ── -->
  <div class="explore-panel" id="explore-panel">

    <!-- back bar -->
    <div id="panel-back-bar">
      <button id="panel-back-btn" type="button">
        <i class="fa-solid fa-chevron-left"></i>
        <span>something else</span>
      </button>
      <span id="panel-breadcrumb">
        <span id="panel-crumb-tag">origin story</span>
        <span class="crumb-sep">·</span>
        <span id="panel-crumb-title">how i got here</span>
      </span>
    </div>

    <!-- journey panel (timeline) -->
    <div class="ep-content" data-panel="journey">
      <div class="ep-header">
        <span class="ep-tag">origin story</span>
        <h3 class="ep-title">how i got here</h3>
        <p class="ep-desc">in chronological order, because i respect your time</p>
      </div>
      <div class="tl-list">
        {timeline.map((entry, i) => (
          <div class="tl-row" data-tl-index={i}>
            <div class="tl-left-col">
              <span class="tl-year">{entry.year}</span>
              <div class="tl-vline"></div>
            </div>
            <div class="tl-card">
              <h4 class="tl-title">{entry.title}</h4>
              <p class="tl-place">{entry.place}</p>
              <p class="tl-desc">{entry.desc}</p>
              <div class="tl-tags">
                {entry.tags.map(t => <span class="tl-tag">{t}</span>)}
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- all other panels -->
    {cards.filter(c => c.id !== "journey").map((c) => (
      <div class="ep-content" data-panel={c.id} style="display:none">
        <div class="ep-header">
          <span class="ep-tag">{c.tag}</span>
          <h3 class="ep-title">{c.title}</h3>
          <p class="ep-desc">{c.preview}</p>
        </div>
        <ul class="ep-list">
          {(c.body ?? []).map(item => (
            <li class="ep-item">
              <span class="ep-bullet">—</span>
              <span>{item}</span>
            </li>
          ))}
        </ul>
      </div>
    ))}

  </div><!-- /explore-panel -->

</BaseLayout>

<style>
  /* ── Shared ──────────────────────────────────── */
  .section-label {
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--accent);
    opacity: 0;
  }

  /* ── Intro section ───────────────────────────── */
  #about-intro {
    min-height: calc(100vh - var(--nav-height));
    display: flex;
    align-items: center;
    padding: 5rem 8%;
  }

  .intro-inner {
    max-width: 780px;
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  .intro-heading {
    font-family: "Cormorant Garamond", serif;
    font-size: clamp(3rem, 7vw, 6rem);
    font-weight: 300;
    color: var(--text);
    line-height: 1.1;
    letter-spacing: 0.02em;
    display: flex;
    flex-direction: column;
    gap: 0.1em;
  }

  .char-wrap  { display: block; overflow: hidden; }
  .char-line  { display: block; transform: translateY(110%); }
  .accent-word .char-line { color: var(--accent); }

  .intro-bio {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    opacity: 0;
  }

  .intro-bio p {
    font-size: clamp(0.95rem, 1.8vw, 1.1rem);
    font-weight: 400;
    color: var(--muted);
    line-height: 1.85;
    max-width: 620px;
  }

  /* ── Explore section ─────────────────────────── */
  #about-explore {
    padding: 4rem 8% 3rem;
  }

  /* ── Card circle ─────────────────────────────── */
  /*   Positions managed by GSAP — no nth-child rules */
  .explore-cards {
    position: relative;
    min-height: 500px;
    margin-bottom: 0;
    overflow: visible;
  }

  .ec-card-wrap {
    position: absolute;
    width: 145px;
    left: 50%;
    top: 50%;
  }

  .ec-card {
    width: 100%;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 0.9rem 1rem;
    display: flex;
    align-items: center;
    gap: 0.6rem;
    cursor: none;
    text-align: left;
    box-shadow: 0 3px 14px rgba(0, 0, 0, 0.45);
    transition: background var(--transition), border-color var(--transition),
                box-shadow var(--transition);
    opacity: 0;
    position: relative;
  }

  .ec-card::before {
    content: '';
    position: absolute;
    left: 0; top: 0; bottom: 0;
    width: 2px;
    border-radius: 4px 0 0 4px;
    background: var(--accent);
    transform: scaleY(0);
    transform-origin: bottom;
    transition: transform 0.25s ease;
  }

  .ec-card:hover {
    background: var(--surface);
    border-color: var(--border-hover);
    box-shadow: 0 8px 28px rgba(0, 0, 0, 0.55);
  }
  .ec-card.active {
    background: var(--surface);
    border-color: var(--accent);
    box-shadow: 0 4px 20px rgba(155, 109, 206, 0.18);
  }
  .ec-card.active::before { transform: scaleY(1); }

  .ec-icon {
    width: 30px;
    height: 30px;
    border: 1px solid var(--border);
    border-radius: 3px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--accent);
    font-size: 12px;
    flex-shrink: 0;
    transition: border-color var(--transition), background var(--transition);
  }

  .ec-card:hover .ec-icon,
  .ec-card.active .ec-icon {
    border-color: var(--border-hover);
    background: var(--accent-dim);
  }

  .ec-meta {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    min-width: 0;
  }

  .ec-tag {
    font-size: 9px;
    font-weight: 500;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--accent);
    opacity: 0.7;
  }

  .ec-title {
    font-size: 0.85rem;
    font-weight: 400;
    color: var(--text);
    letter-spacing: 0.01em;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .ec-arrow {
    font-size: 10px;
    color: var(--muted);
    flex-shrink: 0;
    transition: color var(--transition), transform var(--transition);
    transform: rotate(90deg);
  }

  .ec-card:hover .ec-arrow  { color: var(--accent); transform: rotate(90deg) translateX(-2px); }
  .ec-card.active .ec-arrow { color: var(--accent); transform: rotate(90deg) translateX(-2px); }

  /* ── Dynamic panel ───────────────────────────── */
  .explore-panel {
    border: 1px solid var(--border);
    border-top: 1px solid var(--border-hover);
    background: var(--surface);
    min-height: 320px;
  }

  /* back bar */
  #panel-back-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.6rem 2.5rem;
    border-bottom: 1px solid var(--border);
    background: var(--bg);
    position: sticky;
    top: var(--nav-height);
    z-index: 10;
  }

  #panel-back-btn {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    background: none;
    border: none;
    color: var(--muted);
    font-family: "Montserrat", sans-serif;
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    cursor: none;
    padding: 0;
    transition: color var(--transition);
  }

  #panel-back-btn:hover { color: var(--accent); }

  #panel-back-btn i {
    font-size: 9px;
    transition: transform var(--transition);
  }

  #panel-back-btn:hover i { transform: translateX(-3px); }

  #panel-breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  #panel-crumb-tag   { color: var(--accent); }
  .crumb-sep         { color: var(--muted); opacity: 0.4; }
  #panel-crumb-title { color: var(--muted); }

  .ep-content {
    padding: 2.5rem;
  }

  .ep-header {
    margin-bottom: 2rem;
    padding-bottom: 1.25rem;
    border-bottom: 1px solid var(--border);
  }

  .ep-tag {
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--accent);
    display: block;
    margin-bottom: 0.4rem;
  }

  .ep-title {
    font-family: "Cormorant Garamond", serif;
    font-size: clamp(1.5rem, 3vw, 2.2rem);
    font-weight: 300;
    color: var(--text);
    letter-spacing: 0.03em;
    margin-bottom: 0.35rem;
  }

  .ep-desc {
    font-size: 0.82rem;
    color: var(--muted);
    line-height: 1.7;
    font-style: italic;
  }

  /* generic list panel */
  .ep-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .ep-item {
    display: flex;
    gap: 0.75rem;
    font-size: 0.85rem;
    color: var(--muted);
    line-height: 1.7;
  }

  .ep-bullet {
    color: var(--accent);
    flex-shrink: 0;
    font-weight: 600;
  }

  /* ── Timeline inside panel ───────────────────── */
  .tl-list {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .tl-row {
    display: flex;
    gap: 1.5rem;
    align-items: stretch;
  }

  .tl-left-col {
    display: flex;
    flex-direction: column;
    align-items: center;
    flex-shrink: 0;
    width: 48px;
  }

  .tl-year {
    font-family: "Courier New", monospace;
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.14em;
    color: var(--accent);
    white-space: nowrap;
    padding-top: 0.1rem;
    text-align: center;
  }

  .tl-vline {
    width: 1px;
    flex: 1;
    background: var(--border);
    margin-top: 0.5rem;
    min-height: 1.5rem;
  }

  .tl-row:last-child .tl-vline { display: none; }

  .tl-card {
    flex: 1;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 1.1rem 1.25rem;
    margin-bottom: 1rem;
    transition: border-color var(--transition), background var(--transition);
  }

  .tl-card:hover {
    border-color: var(--border-hover);
    background: rgba(155,109,206,0.03);
  }

  .tl-title {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--text);
    margin-bottom: 0.2rem;
    letter-spacing: 0.01em;
  }

  .tl-place {
    font-size: 11px;
    color: var(--muted);
    letter-spacing: 0.07em;
    margin-bottom: 0.6rem;
    font-style: italic;
  }

  .tl-desc {
    font-size: 0.8rem;
    color: var(--muted);
    line-height: 1.75;
    margin-bottom: 0.85rem;
  }

  .tl-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
  }

  .tl-tag {
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--accent);
    background: var(--accent-dim);
    border: 1px solid rgba(155,109,206,0.2);
    padding: 0.15rem 0.5rem;
    border-radius: 2px;
  }

  /* ── Section Nav (removed — kept for reference) ─────────────────────
  HTML:
    <nav id="about-nav" aria-label="Page sections">
      <div id="about-nav-track"><div id="about-nav-pill"></div></div>
      <button class="anav-btn" data-target="about-intro"   data-index="0" aria-label="intro">
        <span class="anav-dot"></span><span class="anav-label">intro</span>
      </button>
      <button class="anav-btn" data-target="about-explore" data-index="1" aria-label="explore">
        <span class="anav-dot"></span><span class="anav-label">explore</span>
      </button>
    </nav>

  #about-nav {
    position: fixed; right: 2rem; top: 50%; transform: translateY(-50%);
    z-index: 50; display: flex; flex-direction: column;
    align-items: center; gap: 1.8rem; opacity: 0;
  }
  #about-nav-track {
    position: absolute; left: 50%; top: 0; bottom: 0; width: 1px;
    transform: translateX(-50%); background: rgba(255,255,255,0.06);
    pointer-events: none;
  }
  #about-nav-pill {
    position: absolute; left: 50%; transform: translateX(-50%);
    width: 1px; height: 14px; top: 0; will-change: top; filter: blur(0.3px);
    background: linear-gradient(to bottom, transparent, var(--accent), transparent);
  }
  .anav-btn {
    position: relative; display: flex; align-items: center;
    background: none; border: none; cursor: none; padding: 3px; z-index: 1;
  }
  .anav-label {
    position: absolute; right: calc(100% + 0.7rem); font-size: 10px;
    font-weight: 500; letter-spacing: 0.15em; text-transform: uppercase;
    color: var(--muted); opacity: 0.22; white-space: nowrap; pointer-events: none;
    transition: opacity 0.25s ease, color 0.25s ease, transform 0.25s ease;
    transform: translateX(4px);
  }
  .anav-dot {
    width: 5px; height: 5px; border-radius: 50%; background: rgba(155,109,206,0.3);
    flex-shrink: 0; display: block;
    transition: background 0.25s ease, transform 0.25s ease, box-shadow 0.25s ease;
  }
  .anav-btn.active .anav-dot { background: var(--accent); transform: scale(1.5); box-shadow: 0 0 6px rgba(155,109,206,0.7); }
  .anav-btn.active .anav-label { opacity: 0.7; color: var(--text); }
  #about-nav:hover .anav-label { opacity: 0.9; transform: translateX(0); }
  #about-nav:hover .anav-btn.active .anav-label { opacity: 1; color: var(--text); }
  #about-nav:hover .anav-dot { background: rgba(155,109,206,0.55); }
  #about-nav:hover .anav-btn.active .anav-dot { background: var(--accent); }
  ── end Section Nav ── */

  /* ── Two-column desktop layout ──────────────── */
  @media (min-width: 701px) {
    #about-layout {
      display: grid;
      grid-template-columns: 1fr 1fr;
      align-items: start;
    }

    /* left col: intro stays sticky while right scrolls */
    #about-intro {
      padding: 5rem 3rem 5rem 8%;
      min-height: unset;
      height: calc(100vh - var(--nav-height));
      position: sticky;
      top: var(--nav-height);
    }

    .intro-inner { max-width: 100%; }

    /* right col: explore, vertically centered */
    #about-explore {
      padding: 2rem 8% 2rem 3.5rem;
      border-left: 1px solid var(--border);
      display: flex;
      align-items: center;
      min-height: calc(100vh - var(--nav-height));
    }

    .explore-cards { width: 100%; }

  }

  /* ── Mobile ──────────────────────────────────── */
  @media (max-width: 700px) {
    #about-intro   { padding: 4rem 6%; }
    #about-explore { padding: 4rem 6% 2rem; }
    /* #about-nav  { display: none; } */
    .explore-cards { position: static; min-height: unset; display: flex; flex-direction: column; gap: 0.75rem; }
    .ec-card-wrap  { position: static; width: auto; transform: none !important; }
    .ec-card       { opacity: 1; transform: none !important; }
    .ep-content    { padding: 1.5rem; }
    .tl-left-col   { width: 38px; }
    #panel-back-bar { padding: 0.6rem 1.5rem; }
    #panel-crumb-title { display: none; }
    .crumb-sep { display: none; }
  }
</style>

<script>
  import gsap from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  import { ScrollToPlugin }  from "gsap/ScrollToPlugin";
  gsap.registerPlugin(ScrollTrigger, ScrollToPlugin);

  /* ── Glitch reveal ───────────────────────────── */
  const GLITCH = "!<>-_\\/[]{}—=+*^?#@$%&";

  function glitchReveal(el: HTMLElement, finalText: string, duration = 780) {
    const frames = 18;
    const ms = Math.round(duration / frames);
    let frame = 0;
    el.style.opacity = "1";

    const iv = setInterval(() => {
      const progress = frame / frames;
      const revealed = Math.floor(progress * finalText.length);
      let display = "";
      for (let i = 0; i < finalText.length; i++) {
        if (i < revealed) {
          display += Math.random() < 0.07 * (1 - progress)
            ? GLITCH[Math.floor(Math.random() * GLITCH.length)]
            : finalText[i];
        } else {
          display += finalText[i] === " " ? "\u00a0"
            : GLITCH[Math.floor(Math.random() * GLITCH.length)];
        }
      }
      el.textContent = display;
      if (frame < frames - 2 && Math.random() < 0.4) {
        el.style.textShadow = `${+(Math.random()*4-2).toFixed(1)}px 0 rgba(255,0,200,0.6),`
                            + `${+(Math.random()*-4+2).toFixed(1)}px 0 rgba(0,255,255,0.6)`;
      } else {
        el.style.textShadow = "";
      }
      frame++;
      if (frame > frames) {
        clearInterval(iv);
        el.textContent = finalText;
        el.style.textShadow = "";
      }
    }, ms);
  }

  /* ── Intro animations ────────────────────────── */
  function initAbout() {
    const label = document.getElementById("intro-label");
    if (!label) return;

    // Intro section is always above-fold — animate directly, no ScrollTrigger
    gsap.to(label, { opacity: 1, duration: 0.5, ease: "power3.out", delay: 0.2 });

    const lines     = Array.from(document.querySelectorAll<HTMLElement>(".char-line"));
    const lineTexts = lines.map(el => el.textContent ?? "");
    lines.forEach((el, i) => {
      setTimeout(() => {
        gsap.set(el, { y: "0%" });
        glitchReveal(el, lineTexts[i], 780);
      }, 300 + i * 200);
    });

    const bio = document.getElementById("intro-bio");
    if (bio) {
      const paras = bio.querySelectorAll("p");
      gsap.timeline({ delay: 0.65 })
        .to(bio, { opacity: 1, duration: 0.01 })
        .fromTo(paras,
          { opacity: 0, y: 18 },
          { opacity: 1, y: 0, duration: 0.6, stagger: 0.15, ease: "power3.out" }
        );
    }
  }

  /* ── Explore section ─────────────────────────── */
  function initExplore() {
    const ecCards   = Array.from(document.querySelectorAll<HTMLElement>(".ec-card"));
    const ecWraps   = Array.from(document.querySelectorAll<HTMLElement>(".ec-card-wrap"));
    const panelWrap = document.getElementById("explore-panel");
    if (!ecCards.length || !panelWrap) return;

    /* ── Constants ──────────────────────────────── */
    const N      = ecWraps.length;      // 7
    const RX     = 205, RY = 140;       // ellipse radii
    const HALF_W = 73;                  // half of 145px card width
    const HALF_H = 30;                  // approx half card height
    const ROTATIONS = [-2.5, 1.8, -1.2, 2.8, -2, 1.5, -3];
    const FLOAT_DUR = [3.2, 2.8, 3.5, 2.6, 3.8, 3.0, 2.9];
    const SWAY_AMP  = [3.5, 3, 4, 2.5, 3.5, 3, 4];   // ±deg around each card's base rotation
    const SWAY_DUR  = [5.5, 4.8, 6.2, 5.0, 6.8, 5.3, 4.5];

    function calcOrbit(count: number) {
      return Array.from({ length: count }, (_, i) => {
        const rad = ((-90 + i * (360 / count)) * Math.PI) / 180;
        return { x: RX * Math.cos(rad) - HALF_W, y: RY * Math.sin(rad) - HALF_H };
      });
    }

    const ORBIT_7 = calcOrbit(7);
    const ORBIT_6 = calcOrbit(6);
    const CENTER  = { x: -HALF_W, y: -HALF_H };

    /* ── Float helpers ──────────────────────────── */
    const floatTweens:  any[] = new Array(N).fill(null);
    const swayTweens:   any[] = new Array(N).fill(null);
    const baseY = ORBIT_7.map(p => p.y);  // current assigned orbit y per card

    function startFloat(i: number) {
      if (floatTweens[i]) floatTweens[i].kill();
      if (swayTweens[i])  swayTweens[i].kill();
      gsap.set(ecWraps[i], { y: baseY[i] });
      // vertical drift on the wrapper
      floatTweens[i] = gsap.to(ecWraps[i], {
        y: baseY[i] + 8,
        duration: FLOAT_DUR[i],
        ease: "sine.inOut",
        yoyo: true,
        repeat: -1,
        delay: (i * 0.43) % FLOAT_DUR[i],
      });
      // rotation rock: oscillates ±SWAY_AMP around the card's base slant angle
      const lo = ROTATIONS[i] - SWAY_AMP[i];
      const hi = ROTATIONS[i] + SWAY_AMP[i];
      swayTweens[i] = gsap.fromTo(ecCards[i],
        { rotation: lo },
        {
          rotation: hi,
          duration: SWAY_DUR[i],
          ease: "sine.inOut",
          yoyo: true,
          repeat: -1,
          delay: (i * 0.67) % SWAY_DUR[i],
        }
      );
    }

    function stopFloat(i: number) {
      if (floatTweens[i]) { floatTweens[i].kill(); floatTweens[i] = null; }
      if (swayTweens[i])  { swayTweens[i].kill();  swayTweens[i]  = null; }
    }

    /* ── Breadcrumb helper (used by both paths) ──── */
    const crumbTag   = document.getElementById("panel-crumb-tag");
    const crumbTitle = document.getElementById("panel-crumb-title");
    function updateBreadcrumb(i: number) {
      if (crumbTag)   crumbTag.textContent   = ecCards[i].querySelector(".ec-tag")?.textContent   ?? "";
      if (crumbTitle) crumbTitle.textContent = ecCards[i].querySelector(".ec-title")?.textContent ?? "";
    }

    function scrollToPanel() {
      const navH = parseInt(getComputedStyle(document.documentElement).getPropertyValue("--nav-height") || "72");
      gsap.to(window, { scrollTo: { y: panelWrap, offsetY: navH + 12 }, duration: 0.85, ease: "power3.inOut" });
    }

    /* ── Mobile: simple reveal + click, skip orbit ─ */
    if (window.matchMedia("(max-width: 700px)").matches) {
      gsap.set(panelWrap, { opacity: 0, y: 20 });
      panelWrap.style.pointerEvents = "none";
      let mobPanelOpen = false, mobActiveId = "";
      ScrollTrigger.create({
        trigger: "#explore-cards", start: "top 85%", once: true,
        onEnter: () => gsap.to(ecCards, { opacity: 1, duration: 0.5, stagger: 0.08, ease: "power3.out" }),
      });
      ecCards.forEach((card, i) => {
        card.addEventListener("click", () => {
          const id = card.dataset.card; if (!id) return;
          ecCards.forEach(c => c.classList.toggle("active", c === card));
          updateBreadcrumb(i);
          if (!mobPanelOpen) {
            panelWrap.querySelectorAll<HTMLElement>(".ep-content").forEach(el => (el.style.display = "none"));
            const first = panelWrap.querySelector<HTMLElement>(`[data-panel="${id}"]`);
            if (first) first.style.display = "block";
            panelWrap.style.pointerEvents = "auto";
            gsap.to(panelWrap, { opacity: 1, y: 0, duration: 0.5, ease: "power3.out" });
            mobPanelOpen = true; mobActiveId = id;
          } else if (id !== mobActiveId) {
            const cur = panelWrap.querySelector<HTMLElement>(`[data-panel="${mobActiveId}"]`);
            const nxt = panelWrap.querySelector<HTMLElement>(`[data-panel="${id}"]`);
            if (cur && nxt) {
              gsap.to(cur, { opacity: 0, duration: 0.15, onComplete: () => { cur.style.display = "none"; nxt.style.display = "block"; gsap.to(nxt, { opacity: 1, duration: 0.3 }); } });
            }
            mobActiveId = id;
          }
          scrollToPanel();
        });
      });
      document.getElementById("panel-back-btn")?.addEventListener("click", () => {
        const navH = parseInt(getComputedStyle(document.documentElement).getPropertyValue("--nav-height") || "72");
        const cardsEl = document.getElementById("explore-cards");
        if (cardsEl) gsap.to(window, { scrollTo: { y: cardsEl, offsetY: navH + 32 }, duration: 0.85, ease: "power3.inOut" });
      });
      return;
    }

    /* ── Desktop: orbit placement ───────────────── */
    ORBIT_7.forEach((pos, i) => {
      gsap.set(ecWraps[i], { x: pos.x, y: pos.y });
      gsap.set(ecCards[i], { opacity: 0, rotation: ROTATIONS[i] });
    });
    gsap.set(panelWrap, { opacity: 0, y: 20 });
    panelWrap.style.pointerEvents = "none";

    // Orbit cards are always in the viewport — animate directly
    gsap.to(ecCards, {
      opacity: 1, duration: 0.5, delay: 0.3,
      stagger: { amount: 0.45, from: "start" },
      ease: "power3.out",
      onComplete: () => ecWraps.forEach((_, i) => startFloat(i)),
    });

    /* ── Hover ──────────────────────────────────── */
    ecCards.forEach((card, i) => {
      card.addEventListener("mouseenter", () => {
        if (i === centerIdx) return;
        stopFloat(i);
        gsap.to(ecWraps[i], { y: baseY[i] - 6, duration: 0.25, ease: "power2.out" });
        gsap.to(card, { rotation: 0, duration: 0.25, ease: "power2.out" });
      });
      card.addEventListener("mouseleave", () => {
        if (i === centerIdx) return;
        gsap.to(ecWraps[i], {
          y: baseY[i], duration: 0.5, ease: "elastic.out(1, 0.6)",
          onComplete: () => startFloat(i),
        });
        gsap.to(card, { rotation: ROTATIONS[i], duration: 0.5, ease: "elastic.out(1, 0.6)" });
      });
    });

    /* ── Panel helpers ──────────────────────────── */
    let panelOpen = false;
    let activeId  = "";

    function animateTimelineIn() {
      gsap.fromTo(panelWrap.querySelectorAll<HTMLElement>(".tl-row"),
        { opacity: 0, x: -18 },
        { opacity: 1, x: 0, duration: 0.45, stagger: 0.07, ease: "power3.out", delay: 0.1 }
      );
    }
    function animateListIn() {
      gsap.fromTo(panelWrap.querySelectorAll<HTMLElement>(".ep-item"),
        { opacity: 0, x: -14 },
        { opacity: 1, x: 0, duration: 0.4, stagger: 0.08, ease: "power3.out", delay: 0.1 }
      );
    }

    function openPanel(cardId: string) {
      const next = panelWrap.querySelector<HTMLElement>(`[data-panel="${cardId}"]`);
      if (!next) return;

      if (!panelOpen) {
        panelWrap.querySelectorAll<HTMLElement>(".ep-content").forEach(el => (el.style.display = "none"));
        next.style.display = "block";
        panelWrap.style.pointerEvents = "auto";
        gsap.to(panelWrap, {
          opacity: 1, y: 0, duration: 0.5, ease: "power3.out",
          onComplete: () => { if (cardId === "journey") animateTimelineIn(); else animateListIn(); },
        });
        panelOpen = true;
        activeId  = cardId;
        scrollToPanel();
        return;
      }

      if (cardId === activeId) { scrollToPanel(); return; }

      const current = panelWrap.querySelector<HTMLElement>(`[data-panel="${activeId}"]`);
      activeId = cardId;
      if (current) {
        gsap.to(current, {
          opacity: 0, y: -10, duration: 0.2, ease: "power2.in",
          onComplete: () => {
            current.style.display = "none";
            next.style.display = "block";
            gsap.fromTo(next, { opacity: 0, y: 12 }, {
              opacity: 1, y: 0, duration: 0.35, ease: "power3.out",
              onComplete: () => { if (cardId === "journey") animateTimelineIn(); else animateListIn(); },
            });
          },
        });
      }
      scrollToPanel();
    }

    /* ── Center-swap logic ──────────────────────── */
    let centerIdx = -1;

    function selectCard(clickedIdx: number) {
      if (clickedIdx === centerIdx) { resetToOrbit7(); return; }

      const prevCenter = centerIdx;
      centerIdx = clickedIdx;

      /* active class */
      ecCards.forEach((c, i) => c.classList.toggle("active", i === clickedIdx));

      /* clicked card → center */
      stopFloat(clickedIdx);
      gsap.to(ecWraps[clickedIdx], { x: CENTER.x, y: CENTER.y, duration: 0.65, ease: "power3.inOut" });
      gsap.to(ecCards[clickedIdx], { rotation: 0, scale: 1.1, duration: 0.65, ease: "power3.inOut" });

      /* redistribute remaining 6 into ORBIT_6 */
      const remaining = Array.from({ length: N }, (_, i) => i).filter(i => i !== clickedIdx);
      remaining.forEach((cardIdx, j) => {
        const pos = ORBIT_6[j];
        stopFloat(cardIdx);
        baseY[cardIdx] = pos.y;

        gsap.to(ecWraps[cardIdx], {
          x: pos.x, y: pos.y, duration: 0.65, ease: "power3.inOut", delay: 0.02 * j,
          onComplete: () => startFloat(cardIdx),
        });

        if (cardIdx === prevCenter) {
          /* returning card: reset scale */
          gsap.to(ecCards[cardIdx], {
            rotation: ROTATIONS[cardIdx], scale: 1,
            duration: 0.65, ease: "power3.inOut", delay: 0.02 * j,
          });
        }
      });

      /* open/switch panel */
      updateBreadcrumb(clickedIdx);
      const cardId = ecCards[clickedIdx].dataset.card;
      if (cardId) openPanel(cardId);
    }

    ecCards.forEach((card, i) => card.addEventListener("click", () => selectCard(i)));

    /* ── Reset to full 7-orbit on background click ─ */
    function resetToOrbit7() {
      if (centerIdx === -1) return;
      const prevCenter = centerIdx;
      centerIdx = -1;

      ecCards.forEach(c => c.classList.remove("active"));

      ecCards.forEach((card, i) => {
        stopFloat(i);
        baseY[i] = ORBIT_7[i].y;
        gsap.to(ecWraps[i], {
          x: ORBIT_7[i].x, y: ORBIT_7[i].y,
          duration: 0.6, ease: "power3.inOut", delay: 0.015 * i,
          onComplete: () => startFloat(i),
        });
        if (i === prevCenter) {
          gsap.to(card, { rotation: ROTATIONS[i], scale: 1, duration: 0.6, ease: "power3.inOut" });
        }
      });

      if (panelOpen) {
        gsap.to(panelWrap, { opacity: 0, y: 20, duration: 0.4, ease: "power2.in" });
        panelWrap.style.pointerEvents = "none";
        panelOpen = false;
        activeId = "";
      }
    }

    document.getElementById("about-explore")?.addEventListener("click", (e) => {
      if (centerIdx === -1) return;
      if ((e.target as HTMLElement).closest(".ec-card")) return;
      resetToOrbit7();
    });

    /* ── Back button ────────────────────────────── */
    document.getElementById("panel-back-btn")?.addEventListener("click", () => {
      const cardsEl = document.getElementById("explore-cards");
      if (!cardsEl) return;
      const navH = parseInt(getComputedStyle(document.documentElement).getPropertyValue("--nav-height") || "72");
      gsap.to(window, { scrollTo: { y: cardsEl, offsetY: navH + 32 }, duration: 0.85, ease: "power3.inOut" });
    });
  }

  /* ── Section Nav (removed — kept for reference) ─────────────────────
  function initAboutNav() {
    const nav  = document.getElementById("about-nav");
    const pill = document.getElementById("about-nav-pill");
    const btns = Array.from(document.querySelectorAll<HTMLElement>(".anav-btn"));
    if (!nav || !pill || !btns.length) return;

    const sections = btns.map(b => document.getElementById(b.dataset.target!)!);

    gsap.to(nav, { opacity: 1, duration: 0.6, delay: 0.8, ease: "power2.out" });

    function setPill(i: number) {
      const navRect = nav.getBoundingClientRect();
      const btnRect = btns[i].getBoundingClientRect();
      const cy = btnRect.top + btnRect.height / 2 - navRect.top;
      gsap.to(pill, { top: cy - 7, duration: 0.45, ease: "power3.inOut" });
    }

    function setActive(i: number) {
      btns.forEach((b, j) => b.classList.toggle("active", j === i));
      setPill(i);
    }

    let scrolling = false;
    const observer = new IntersectionObserver(
      (entries) => {
        if (scrolling) return;
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            const i = sections.indexOf(entry.target as HTMLElement);
            if (i !== -1) setActive(i);
          }
        });
      },
      { threshold: 0.3 }
    );
    sections.forEach(s => s && observer.observe(s));

    requestAnimationFrame(() => setPill(0));
    setActive(0);

    btns.forEach((btn, i) => {
      btn.addEventListener("click", () => {
        const target = sections[i];
        if (!target) return;
        scrolling = true;
        setActive(i);
        const navH = parseInt(getComputedStyle(document.documentElement).getPropertyValue("--nav-height") || "72");
        gsap.to(window, {
          scrollTo: target.getBoundingClientRect().top + window.scrollY - navH - 24,
          duration: 0.9,
          ease: "power3.inOut",
          onComplete: () => { scrolling = false; },
        });
        // glitch flash on heading
        const heading = target.querySelector<HTMLElement>("h1, h2");
        if (heading) {
          const orig = heading.textContent ?? "";
          const G = "!<>-_\\/[]{}—=+*^?#@$%&";
          let f = 0;
          const iv = setInterval(() => {
            heading.textContent = orig.split("").map(c =>
              c === " " ? " " : Math.random() < 0.45 ? G[Math.floor(Math.random()*G.length)] : c
            ).join("");
            heading.style.textShadow = Math.random() < 0.5
              ? `${(Math.random()*3-1.5).toFixed(1)}px 0 rgba(255,0,200,0.55),${(Math.random()*-3+1.5).toFixed(1)}px 0 rgba(0,255,255,0.55)`
              : "";
            if (++f > 7) {
              clearInterval(iv);
              heading.textContent = orig;
              heading.style.textShadow = "";
            }
          }, 55);
        }
      });
    });

    return () => observer.disconnect();
  }
  ── end Section Nav ── */

  document.addEventListener("astro:page-load", initAbout);
  document.addEventListener("astro:page-load", initExplore);
  // document.addEventListener("astro:page-load", initAboutNav);
</script>
