---
const path = Astro.url.pathname;
const links = [
  { href: "/about",    label: "About" },
  { href: "/projects", label: "Projects" },
  { href: "/contact",  label: "Contact" },
];
---

<header>
  <a href="/"><img src="/logos/purple-text/mark-gosh-ligature-heavy-purple-text.svg" id="logo-img" alt="Gosvindraj" /></a>
  <nav>
    <ul class="nav_links">
      {links.map((link) => (
        <li>
          <a
            href={link.href}
            class={path.startsWith(link.href) ? "active" : ""}
          >
            <span class="nav-roll">
              <span class="nav-roll-inner">
                <span class="nav-roll-text">{link.label}</span>
                <span class="nav-roll-text" aria-hidden="true">{link.label}</span>
              </span>
            </span>
          </a>
        </li>
      ))}
    </ul>
  </nav>
  <div class="toggle_btn" aria-label="Toggle menu">
    <i class="fa-solid fa-bars"></i>
  </div>
  <ul class="dropdown_menu">
    {links.map((link) => (
      <li><a href={link.href}>{link.label}</a></li>
    ))}
  </ul>
</header>

<script>
  import gsap from "gsap";

  function initNavbar() {
    /* ── Translucent nav on homepage ─────────── */
    const isHome = window.location.pathname === "/" || window.location.pathname === "/index.html";
    document.querySelector("header")?.classList.toggle("nav-translucent", isHome);

    /* ── Mobile toggle ───────────────────────── */
    const toggleBtn    = document.querySelector(".toggle_btn");
    const dropdownMenu = document.querySelector(".dropdown_menu");

    toggleBtn?.addEventListener("click", () => dropdownMenu?.classList.toggle("open"));
    dropdownMenu?.querySelectorAll("a").forEach((a) => {
      a.addEventListener("click", () => dropdownMenu?.classList.remove("open"));
    });

    /* ── Nav text roll ───────────────────────── */
    document.querySelectorAll(".nav_links a").forEach((link) => {
      const inner = link.querySelector<HTMLElement>(".nav-roll-inner");
      if (!inner) return;

      gsap.set(inner, { y: "0%" });

      link.addEventListener("mouseenter", () => {
        gsap.to(inner, { y: "-50%", duration: 0.28, ease: "power2.inOut" });
      });

      link.addEventListener("mouseleave", () => {
        gsap.set(inner, { y: "50%" });
        gsap.to(inner, { y: "0%", duration: 0.22, ease: "power2.out" });
      });
    });

    /* ── Logo magnetic + glitch ─────────────── */
    const logoWrap = document.querySelector<HTMLElement>("header > a");
    const logoImg  = document.getElementById("logo-img") as HTMLImageElement | null;

    if (logoWrap && logoImg) {
      logoWrap.addEventListener("mousemove", (e) => {
        const rect = logoWrap.getBoundingClientRect();
        const dx = (e.clientX - (rect.left + rect.width  / 2)) * 0.3;
        const dy = (e.clientY - (rect.top  + rect.height / 2)) * 0.3;
        gsap.to(logoImg, { x: dx, y: dy, duration: 0.35, ease: "power2.out" });
      });

      logoWrap.addEventListener("mouseleave", () => {
        gsap.to(logoImg, { x: 0, y: 0, duration: 0.7, ease: "elastic.out(1, 0.4)" });
      });

      logoWrap.addEventListener("mouseenter", () => {
        const tl = gsap.timeline();
        tl.to(logoImg, { skewX: 6,  opacity: 0.7, duration: 0.06, ease: "none" })
          .to(logoImg, { skewX: -5, opacity: 1,   duration: 0.06, ease: "none" })
          .to(logoImg, { skewX: 3,  opacity: 0.8, duration: 0.05, ease: "none" })
          .to(logoImg, { skewX: 0,  opacity: 1,   duration: 0.08, ease: "none" });
      });
    }

  }

  document.addEventListener("astro:page-load", initNavbar);
</script>
