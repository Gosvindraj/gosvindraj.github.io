---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection, getEntry, render } from "astro:content";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post) => ({ params: { slug: post.id } }));
}

const { slug } = Astro.params;
const post = await getEntry("blog", slug!);
if (!post) return Astro.redirect("/blog");

const { Content } = await render(post);

function formatDate(date: Date) {
  return date.toLocaleDateString("en-GB", { day: "numeric", month: "long", year: "numeric" });
}
---
<BaseLayout title={`Gosvindraj | ${post.data.title}`} description={post.data.description}>
  <section id="post">
    <div class="post-inner">
      <div class="post-header">
        <a href="/blog" class="back-link">
          <i class="fa-solid fa-arrow-left"></i>
          <span>all posts</span>
        </a>
        <div class="post-meta">
          <span class="post-date">{formatDate(post.data.date)}</span>
          {post.data.tags && post.data.tags.map((tag: string) => (
            <span class="post-tag">{tag}</span>
          ))}
        </div>
        <h1 class="post-title">{post.data.title}</h1>
        {post.data.description && <p class="post-desc">{post.data.description}</p>}
      </div>

      <article class="post-body">
        <Content />
      </article>
    </div>
  </section>
</BaseLayout>

<style>
  #post {
    min-height: calc(100vh - var(--nav-height));
    padding: 4rem 8%;
  }

  .post-inner {
    max-width: 680px;
    opacity: 0;
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--muted);
    border: 1px solid var(--border);
    padding: 0.55rem 1.1rem;
    border-radius: 2px;
    transition: color 0.2s, border-color 0.2s, background 0.2s;
    margin-bottom: 2.5rem;
    display: inline-flex;
  }

  .back-link i { font-size: 10px; transition: transform 0.2s; }
  .back-link:hover { color: var(--text); border-color: var(--border-hover); background: var(--accent-dim); }
  .back-link:hover i { transform: translateX(-3px); }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1rem;
  }

  .post-date {
    font-family: "Courier New", monospace;
    font-size: 11px;
    letter-spacing: 0.08em;
    color: var(--muted);
  }

  .post-tag {
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent);
    opacity: 0.7;
  }

  .post-title {
    font-family: "Cormorant Garamond", serif;
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 300;
    color: var(--text);
    letter-spacing: 0.03em;
    line-height: 1.15;
    margin-bottom: 0.75rem;
  }

  .post-desc {
    font-size: 0.875rem;
    color: var(--muted);
    line-height: 1.8;
    margin-bottom: 2.5rem;
  }

  .post-body {
    border-top: 1px solid var(--border);
    padding-top: 2.5rem;
    font-size: 0.9rem;
    color: var(--text);
    line-height: 1.9;
  }

  .post-body :global(p)      { margin-bottom: 1.4rem; }
  .post-body :global(h2)     { font-family: "Cormorant Garamond", serif; font-size: 1.6rem; font-weight: 300; color: var(--text); margin: 2.5rem 0 1rem; }
  .post-body :global(h3)     { font-size: 1rem; font-weight: 500; color: var(--text); margin: 2rem 0 0.75rem; letter-spacing: 0.04em; }
  .post-body :global(a)      { color: var(--accent); text-decoration: underline; text-underline-offset: 3px; }
  .post-body :global(ul),
  .post-body :global(ol)     { padding-left: 1.5rem; margin-bottom: 1.4rem; }
  .post-body :global(li)     { margin-bottom: 0.4rem; }
  .post-body :global(code)   { font-family: "Courier New", monospace; font-size: 0.82em; background: var(--surface); padding: 0.15em 0.4em; border-radius: 2px; color: var(--accent); }
  .post-body :global(pre)    { background: var(--surface); border: 1px solid var(--border); border-radius: 4px; padding: 1.25rem; overflow-x: auto; margin-bottom: 1.4rem; }
  .post-body :global(pre code) { background: none; padding: 0; color: var(--text); }
  .post-body :global(blockquote) { border-left: 2px solid var(--accent); padding-left: 1.25rem; color: var(--muted); margin: 1.5rem 0; font-style: italic; }
  .post-body :global(hr)     { border: none; border-top: 1px solid var(--border); margin: 2.5rem 0; }

  @media (max-width: 600px) {
    #post { padding: 4rem 6%; }
  }
</style>

<script>
  import gsap from "gsap";

  function initPost() {
    const inner = document.querySelector<HTMLElement>(".post-inner");
    gsap.fromTo(inner, { y: 20, opacity: 0 }, { y: 0, opacity: 1, duration: 0.6, ease: "power3.out", delay: 0.1 });
  }

  document.addEventListener("astro:page-load", initPost);
</script>
