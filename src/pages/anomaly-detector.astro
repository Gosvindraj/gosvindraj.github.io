---
import BaseLayout from "../layouts/BaseLayout.astro";
---
<BaseLayout title="Gosvindraj | Avalanche Anomaly Detector">
  <section id="project-anomaly">
    <div class="project-inner">

      <!-- ── Left panel ── -->
      <div class="project-header">
        <p class="section-label">project 03</p>
        <h1 class="project-title">Avalanche<br>Anomaly<br>Detector</h1>
        <p class="project-desc">
          paste an Avalanche C-Chain wallet address to analyze its recent
          transactions for anomalous behaviour. detection runs server-side
          using an Isolation Forest model on value, gas, and timing patterns.
        </p>

        <div class="legend">
          <div class="legend-item"><span class="dot dot-normal"></span>normal</div>
          <div class="legend-item"><span class="dot dot-suspicious"></span>suspicious</div>
          <div class="legend-item"><span class="dot dot-anomalous"></span>anomalous</div>
        </div>

        <a href="/projects" class="back-link">
          <i class="fa-solid fa-arrow-left"></i>
          <span>back to projects</span>
        </a>
      </div>

      <!-- ── Right panel ── -->
      <div class="anomaly-wrap">

        <div class="input-row">
          <input
            type="text"
            id="address-input"
            placeholder="0x... Avalanche C-Chain address"
            spellcheck="false"
            autocomplete="off"
            maxlength="42"
          />
          <button id="analyze-btn" type="button" data-magnetic>
            <span id="btn-text">Analyze</span>
            <i class="fa-solid fa-arrow-right"></i>
          </button>
        </div>

        <p class="info-msg" id="info-msg"></p>

        <div id="results" class="hidden">
          <div class="summary" id="summary"></div>
          <div class="table-wrap">
            <table id="tx-table">
              <thead>
                <tr>
                  <th>Hash</th>
                  <th>Time</th>
                  <th>Value</th>
                  <th>Gas</th>
                  <th>Score</th>
                  <th>Status</th>
                  <th></th>
                </tr>
              </thead>
              <tbody id="tx-body"></tbody>
            </table>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ── Modal ── -->
  <div id="tx-modal" class="modal-backdrop hidden" aria-modal="true" role="dialog">
    <div class="modal-panel" id="modal-panel">
      <button class="modal-close" id="modal-close" aria-label="Close">
        <i class="fa-solid fa-xmark"></i>
      </button>

      <div class="modal-header">
        <div class="modal-flag-row">
          <span class="modal-badge" id="modal-badge"></span>
          <span class="modal-score" id="modal-score"></span>
        </div>
        <div class="modal-hash-row">
          <span class="modal-hash-val" id="modal-hash-display"></span>
          <div class="modal-hash-actions">
            <button class="icon-btn" id="modal-copy" title="Copy hash">
              <i class="fa-regular fa-copy"></i>
            </button>
            <a class="icon-btn" id="modal-snowtrace" href="#" target="_blank" rel="noopener" title="View on Snowtrace">
              <i class="fa-solid fa-arrow-up-right-from-square"></i>
            </a>
          </div>
        </div>
      </div>

      <div class="modal-meta" id="modal-meta"></div>

      <div class="modal-divider"></div>

      <div class="modal-verdict" id="modal-verdict"></div>

      <div class="modal-features" id="modal-features"></div>
    </div>
  </div>
</BaseLayout>

<style>
  #project-anomaly {
    min-height: calc(100vh - var(--nav-height));
    display: flex;
    align-items: flex-start;
    padding: 4rem 8%;
  }

  .project-inner {
    width: 100%;
    display: flex;
    align-items: flex-start;
    gap: 5rem;
  }

  /* ── Left panel ── */
  .project-header {
    flex: 0 0 260px;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    opacity: 0;
    position: sticky;
    top: calc(var(--nav-height) + 2rem);
  }

  .section-label {
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--accent);
  }

  .project-title {
    font-family: "Cormorant Garamond", serif;
    font-size: clamp(2rem, 3.5vw, 3rem);
    font-weight: 300;
    color: var(--text);
    letter-spacing: 0.03em;
    line-height: 1.1;
  }

  .project-desc {
    font-size: 0.82rem;
    color: var(--muted);
    line-height: 1.9;
  }

  .legend {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .legend-item {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--muted);
  }

  .dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .dot-normal    { background: #6fcf97; }
  .dot-suspicious{ background: #f2994a; }
  .dot-anomalous { background: #eb5757; }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--muted);
    border: 1px solid var(--border);
    padding: 0.55rem 1.1rem;
    border-radius: 2px;
    cursor: none;
    transition: color var(--transition), border-color var(--transition), background var(--transition);
    align-self: flex-start;
  }

  .back-link i { font-size: 10px; transition: transform var(--transition); }
  .back-link:hover { color: var(--text); border-color: var(--border-hover); background: var(--accent-dim); }
  .back-link:hover i { transform: translateX(-3px); }

  /* ── Right panel ── */
  .anomaly-wrap {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    opacity: 0;
  }

  .input-row {
    display: flex;
    gap: 0;
    border: 1px solid var(--border);
    border-radius: 2px;
    overflow: hidden;
    transition: border-color var(--transition);
  }

  .input-row:focus-within { border-color: var(--border-hover); }

  #address-input {
    flex: 1;
    background: var(--surface);
    border: none;
    outline: none;
    padding: 0.85rem 1.1rem;
    font-family: "Courier New", monospace;
    font-size: 0.82rem;
    color: var(--text);
    letter-spacing: 0.04em;
    min-width: 0;
  }

  #address-input::placeholder { color: var(--muted); font-family: "Montserrat", sans-serif; font-size: 0.8rem; letter-spacing: 0.02em; }

  #address-input::selection {
    background: rgba(155, 109, 206, 0.35);
    color: #fff;
  }

  #analyze-btn {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    background: none;
    border: none;
    border-left: 1px solid var(--border);
    color: var(--muted);
    font-family: "Montserrat", sans-serif;
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 0.85rem 1.4rem;
    cursor: none;
    transition: color var(--transition), background var(--transition), border-color var(--transition);
    white-space: nowrap;
    will-change: transform;
  }

  #analyze-btn i { font-size: 10px; transition: transform var(--transition); }
  #analyze-btn:hover { color: var(--text); background: var(--accent-dim); border-color: var(--border-hover); }
  #analyze-btn:hover i { transform: translateX(3px); }
  #analyze-btn:disabled { opacity: 0.4; pointer-events: none; }

  .info-msg {
    font-size: 0.8rem;
    color: var(--muted);
    letter-spacing: 0.03em;
    min-height: 1.2em;
  }

  .info-msg.error { color: #eb5757; }

  /* ── Summary ── */
  .summary {
    display: flex;
    gap: 2rem;
    padding: 0.9rem 0;
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    flex-wrap: wrap;
  }

  .stat {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .stat-label {
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--muted);
  }

  .stat-val {
    font-family: "Cormorant Garamond", serif;
    font-size: 1.6rem;
    font-weight: 300;
    color: var(--text);
    line-height: 1;
  }

  .stat-val.has-anomalies  { color: #eb5757; }
  .stat-val.has-suspicious { color: #f2994a; }

  /* ── Table ── */
  .table-wrap { overflow-x: auto; }

  #tx-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.8rem;
  }

  #tx-table th {
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--muted);
    text-align: left;
    padding: 0.6rem 0.75rem;
    border-bottom: 1px solid var(--border);
    white-space: nowrap;
  }

  #tx-table th:last-child { width: 32px; }

  .tx-row { cursor: none; transition: background var(--transition); }

  .tx-row td {
    padding: 0.7rem 0.75rem;
    border-bottom: 1px solid var(--border);
    color: var(--muted);
    vertical-align: middle;
    white-space: nowrap;
  }

  .tx-row:hover td { background: var(--surface); }

  .tx-row:hover .row-arrow { opacity: 1; transform: translateX(2px); }

  .td-hash a {
    font-family: "Courier New", monospace;
    font-size: 0.78rem;
    color: var(--accent);
    letter-spacing: 0.03em;
    cursor: none;
    transition: opacity var(--transition);
  }

  .td-hash a:hover { opacity: 0.7; }

  .td-value { font-family: "Courier New", monospace; color: var(--text); }

  /* score bar */
  .score-wrap { display: flex; align-items: center; gap: 0.5rem; }

  .score-bar-bg {
    width: 60px;
    height: 4px;
    background: var(--border);
    border-radius: 2px;
    overflow: hidden;
    flex-shrink: 0;
  }

  .score-bar-fill { height: 100%; border-radius: 2px; }

  .score-num {
    font-family: "Courier New", monospace;
    font-size: 0.75rem;
    color: var(--muted);
    min-width: 36px;
  }

  /* status badge */
  .badge {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.25rem 0.55rem;
    border-radius: 2px;
  }

  .badge-dot { width: 5px; height: 5px; border-radius: 50%; }

  .badge-normal     { background: rgba(111,207,151,0.1); color: #6fcf97; }
  .badge-normal     .badge-dot { background: #6fcf97; }
  .badge-suspicious { background: rgba(242,153,74,0.1);  color: #f2994a; }
  .badge-suspicious .badge-dot { background: #f2994a; }
  .badge-anomalous  { background: rgba(235,87,87,0.1);   color: #eb5757; }
  .badge-anomalous  .badge-dot { background: #eb5757; }

  /* row arrow hint */
  .row-arrow {
    color: var(--muted);
    font-size: 10px;
    opacity: 0;
    transition: opacity var(--transition), transform var(--transition);
  }

  .hidden { display: none !important; }

  /* ── Modal ── */
  .modal-backdrop {
    position: fixed;
    inset: 0;
    z-index: 900;
    background: rgba(0, 0, 0, 0.65);
    backdrop-filter: blur(4px);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1.5rem;
  }

  .modal-panel {
    position: relative;
    background: var(--bg);
    border: 1px solid var(--border-hover);
    border-radius: 3px;
    width: 100%;
    max-width: 540px;
    max-height: 88vh;
    overflow-y: auto;
    padding: 2rem;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .modal-close {
    position: absolute;
    top: 1rem;
    right: 1rem;
    width: 28px;
    height: 28px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: none;
    border: 1px solid var(--border);
    border-radius: 2px;
    color: var(--muted);
    font-size: 12px;
    cursor: none;
    transition: color var(--transition), border-color var(--transition), background var(--transition);
  }

  .modal-close:hover { color: var(--text); border-color: var(--border-hover); background: var(--surface); }

  /* modal header */
  .modal-header { display: flex; flex-direction: column; gap: 0.6rem; }

  .modal-flag-row { display: flex; align-items: center; gap: 0.75rem; }

  .modal-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 0.3rem 0.65rem;
    border-radius: 2px;
  }

  .modal-score {
    font-family: "Courier New", monospace;
    font-size: 0.75rem;
    color: var(--muted);
  }

  .modal-hash-row {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .modal-hash-val {
    font-family: "Courier New", monospace;
    font-size: 0.78rem;
    color: var(--text);
    letter-spacing: 0.03em;
    word-break: break-all;
    flex: 1;
    min-width: 0;
  }

  .modal-hash-actions { display: flex; gap: 0.4rem; flex-shrink: 0; }

  .icon-btn {
    width: 26px;
    height: 26px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: none;
    border: 1px solid var(--border);
    border-radius: 2px;
    color: var(--muted);
    font-size: 11px;
    cursor: none;
    transition: color var(--transition), border-color var(--transition), background var(--transition);
    text-decoration: none;
  }

  .icon-btn:hover { color: var(--text); border-color: var(--border-hover); background: var(--surface); }

  /* modal meta */
  .modal-meta {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.6rem 1.5rem;
  }

  .meta-item { display: flex; flex-direction: column; gap: 0.2rem; }

  .meta-label {
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--muted);
  }

  .meta-val {
    font-family: "Courier New", monospace;
    font-size: 0.78rem;
    color: var(--text);
    word-break: break-all;
  }

  .modal-divider {
    height: 1px;
    background: var(--border);
  }

  /* verdict */
  .modal-verdict {
    font-size: 0.82rem;
    color: var(--muted);
    line-height: 1.9;
  }

  /* feature bars */
  .modal-features {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .feature-row {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .feature-label {
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--muted);
    width: 68px;
    flex-shrink: 0;
  }

  .feature-track {
    flex: 1;
    height: 3px;
    background: var(--border);
    border-radius: 2px;
    overflow: hidden;
  }

  .feature-fill {
    height: 100%;
    border-radius: 2px;
    opacity: 0.8;
  }

  .feature-pct {
    font-family: "Courier New", monospace;
    font-size: 10px;
    color: var(--muted);
    width: 56px;
    flex-shrink: 0;
    text-align: right;
  }

  @media (max-width: 960px) {
    .project-inner { flex-direction: column; gap: 3rem; }
    .project-header { flex: none; position: static; }
  }

  @media (max-width: 600px) {
    #project-anomaly { padding: 3rem 6%; }
    .modal-meta { grid-template-columns: 1fr; }
  }
</style>

<script>
  import gsap from "gsap";

  interface FeatureStat { raw: number; pct: number; }

  interface TxResult {
    hash: string;
    timestamp: number;
    from: string;
    to: string | null;
    valueAvax: number;
    gasUsed: number;
    score: number;
    flag: "normal" | "suspicious" | "anomalous";
    features: {
      value:     FeatureStat;
      gas:       FeatureStat;
      timeDelta: FeatureStat;
    };
  }

  function timeAgo(ts: number): string {
    const diff = Math.floor(Date.now() / 1000) - ts;
    if (diff < 60)    return `${diff}s ago`;
    if (diff < 3600)  return `${Math.floor(diff / 60)}m ago`;
    if (diff < 86400) return `${Math.floor(diff / 3600)}h ago`;
    return `${Math.floor(diff / 86400)}d ago`;
  }

  function fmtDate(ts: number): string {
    return new Date(ts * 1000).toLocaleString("en-US", {
      month: "short", day: "numeric", year: "numeric",
      hour: "2-digit", minute: "2-digit",
    });
  }

  function fmtAvax(v: number): string {
    if (v === 0)       return "0 AVAX";
    if (v < 0.0001)    return "<0.0001 AVAX";
    return `${v.toLocaleString("en-US", { maximumFractionDigits: 4 })} AVAX`;
  }

  function scoreColor(flag: string): string {
    if (flag === "anomalous")  return "#eb5757";
    if (flag === "suspicious") return "#f2994a";
    return "#6fcf97";
  }

  function truncate(addr: string, head = 8, tail = 6): string {
    if (!addr) return "—";
    return `${addr.slice(0, head)}...${addr.slice(-tail)}`;
  }

  function explain(tx: TxResult): string {
    const { value, gas, timeDelta } = tx.features;
    const lines: string[] = [];

    if (tx.flag === "normal") {
      lines.push("This transaction fits within the wallet's typical activity pattern.");
    } else {
      lines.push(
        tx.flag === "anomalous"
          ? "This transaction stands out significantly from the wallet's typical behaviour."
          : "This transaction shows some unusual characteristics."
      );
    }

    if (value.pct >= 90)
      lines.push(`Value of ${fmtAvax(value.raw)} is higher than ${value.pct}% of this wallet's transactions — unusually large.`);
    else if (value.pct <= 10 && value.raw === 0)
      lines.push(`Zero AVAX transferred — likely a contract interaction or token swap.`);
    else if (value.pct <= 10)
      lines.push(`Value of ${fmtAvax(value.raw)} is lower than ${100 - value.pct}% of this wallet's transactions.`);

    if (gas.pct >= 90)
      lines.push(`Gas used (${gas.raw.toLocaleString()}) is higher than ${gas.pct}% of transactions — indicates a complex contract execution.`);
    else if (gas.pct <= 10)
      lines.push(`Gas used (${gas.raw.toLocaleString()}) is very low — typical of a simple transfer.`);

    if (timeDelta.raw === 0) {
      lines.push(`First transaction in the analyzed set — no prior timing reference.`);
    } else if (timeDelta.pct <= 5) {
      const secs = timeDelta.raw;
      lines.push(`Sent only ${secs < 60 ? secs + "s" : Math.round(secs / 60) + "m"} after the previous transaction — unusually rapid succession for this wallet.`);
    } else if (timeDelta.pct >= 90) {
      const hrs = Math.round(timeDelta.raw / 3600);
      lines.push(`Over ${hrs}h gap since the previous transaction — longer dormancy period than usual for this wallet.`);
    }

    return lines.join(" ");
  }

  // ── Modal ──────────────────────────────────────────────────────────────────

  let modalOpen = false;

  function openModal(tx: TxResult) {
    const backdrop   = document.getElementById("tx-modal")!;
    const panel      = document.getElementById("modal-panel")!;
    const badge      = document.getElementById("modal-badge")!;
    const scoreEl    = document.getElementById("modal-score")!;
    const hashDisp   = document.getElementById("modal-hash-display")!;
    const copyBtn    = document.getElementById("modal-copy")!;
    const snowtrace  = document.getElementById("modal-snowtrace") as HTMLAnchorElement;
    const metaEl     = document.getElementById("modal-meta")!;
    const verdictEl  = document.getElementById("modal-verdict")!;
    const featuresEl = document.getElementById("modal-features")!;

    const color = scoreColor(tx.flag);

    // badge
    badge.className = `modal-badge badge-${tx.flag}`;
    badge.innerHTML = `<span class="badge-dot"></span>${tx.flag}`;

    // score
    scoreEl.textContent = `score ${tx.score.toFixed(3)}`;

    // hash
    hashDisp.textContent = tx.hash;
    snowtrace.href = `https://snowtrace.io/tx/${tx.hash}`;

    // copy
    copyBtn.onclick = () => {
      navigator.clipboard.writeText(tx.hash).then(() => {
        const icon = copyBtn.querySelector("i")!;
        icon.className = "fa-solid fa-check";
        setTimeout(() => { icon.className = "fa-regular fa-copy"; }, 1500);
      });
    };

    // meta grid
    metaEl.innerHTML = `
      <div class="meta-item">
        <span class="meta-label">Time</span>
        <span class="meta-val">${fmtDate(tx.timestamp)}</span>
      </div>
      <div class="meta-item">
        <span class="meta-label">Value</span>
        <span class="meta-val" style="color:${color}">${fmtAvax(tx.valueAvax)}</span>
      </div>
      <div class="meta-item">
        <span class="meta-label">From</span>
        <span class="meta-val" title="${tx.from}">${truncate(tx.from)}</span>
      </div>
      <div class="meta-item">
        <span class="meta-label">To</span>
        <span class="meta-val" title="${tx.to ?? ''}">${tx.to ? truncate(tx.to) : '—'}</span>
      </div>
      <div class="meta-item">
        <span class="meta-label">Gas used</span>
        <span class="meta-val">${tx.gasUsed.toLocaleString()}</span>
      </div>
    `;

    // verdict
    verdictEl.textContent = explain(tx);

    // feature bars
    const { value, gas, timeDelta } = tx.features;
    featuresEl.innerHTML = [
      ["Value",    value.pct],
      ["Gas used", gas.pct],
      ["Time gap", timeDelta.pct],
    ].map(([label, pct]) => `
      <div class="feature-row">
        <span class="feature-label">${label}</span>
        <div class="feature-track">
          <div class="feature-fill" style="width:${pct}%; background:${color}"></div>
        </div>
        <span class="feature-pct">${pct}th pct</span>
      </div>
    `).join("");

    // show
    backdrop.classList.remove("hidden");
    panel.scrollTop = 0;
    modalOpen = true;
    gsap.fromTo(panel, { opacity: 0, scale: 0.96, y: 12 }, { opacity: 1, scale: 1, y: 0, duration: 0.3, ease: "power3.out" });
  }

  function closeModal() {
    const backdrop = document.getElementById("tx-modal")!;
    const panel    = document.getElementById("modal-panel")!;
    gsap.to(panel, {
      opacity: 0, scale: 0.96, y: 8, duration: 0.2, ease: "power2.in",
      onComplete: () => { backdrop.classList.add("hidden"); modalOpen = false; },
    });
  }

  // ── Results render ─────────────────────────────────────────────────────────

  function renderResults(txs: TxResult[]) {
    const results = document.getElementById("results")!;
    const summary = document.getElementById("summary")!;
    const tbody   = document.getElementById("tx-body")!;

    const total      = txs.length;
    const anomalous  = txs.filter(t => t.flag === "anomalous").length;
    const suspicious = txs.filter(t => t.flag === "suspicious").length;

    summary.innerHTML = `
      <div class="stat">
        <span class="stat-label">Analyzed</span>
        <span class="stat-val">${total}</span>
      </div>
      <div class="stat">
        <span class="stat-label">Anomalous</span>
        <span class="stat-val ${anomalous > 0 ? "has-anomalies" : ""}">${anomalous}</span>
      </div>
      <div class="stat">
        <span class="stat-label">Suspicious</span>
        <span class="stat-val ${suspicious > 0 ? "has-suspicious" : ""}">${suspicious}</span>
      </div>
      <div class="stat">
        <span class="stat-label">Normal</span>
        <span class="stat-val">${total - anomalous - suspicious}</span>
      </div>
    `;

    tbody.innerHTML = txs.map((tx, i) => {
      const short = `${tx.hash.slice(0, 8)}...${tx.hash.slice(-6)}`;
      const color = scoreColor(tx.flag);
      const barW  = Math.round(tx.score * 100);
      return `
        <tr class="tx-row" data-idx="${i}">
          <td class="td-hash">
            <a href="https://snowtrace.io/tx/${tx.hash}" target="_blank" rel="noopener" onclick="event.stopPropagation()">${short}</a>
          </td>
          <td>${timeAgo(tx.timestamp)}</td>
          <td class="td-value">${fmtAvax(tx.valueAvax)}</td>
          <td>${tx.gasUsed.toLocaleString()}</td>
          <td>
            <div class="score-wrap">
              <div class="score-bar-bg">
                <div class="score-bar-fill" style="width:${barW}%; background:${color}"></div>
              </div>
              <span class="score-num">${tx.score.toFixed(3)}</span>
            </div>
          </td>
          <td>
            <span class="badge badge-${tx.flag}">
              <span class="badge-dot"></span>${tx.flag}
            </span>
          </td>
          <td><i class="fa-solid fa-chevron-right row-arrow"></i></td>
        </tr>
      `;
    }).join("");

    // attach click to open modal
    tbody.querySelectorAll<HTMLElement>(".tx-row").forEach(row => {
      row.addEventListener("click", () => {
        const idx = Number(row.dataset.idx);
        openModal(txs[idx]);
      });
    });

    results.classList.remove("hidden");
    gsap.fromTo(results, { opacity: 0, y: 10 }, { opacity: 1, y: 0, duration: 0.4, ease: "power3.out" });
  }

  // ── Init ───────────────────────────────────────────────────────────────────

  function initAnomaly() {
    const header  = document.querySelector<HTMLElement>(".project-header");
    const wrap    = document.querySelector<HTMLElement>(".anomaly-wrap");
    if (!header) return;

    gsap.fromTo(header, { opacity: 0, y: 20 }, { opacity: 1, y: 0, duration: 0.6, ease: "power3.out", delay: 0.1 });
    gsap.fromTo(wrap,   { opacity: 0, y: 20 }, { opacity: 1, y: 0, duration: 0.6, ease: "power3.out", delay: 0.25 });

    const input   = document.getElementById("address-input") as HTMLInputElement;
    const btn     = document.getElementById("analyze-btn")   as HTMLButtonElement;
    const btnText = document.getElementById("btn-text")      as HTMLElement;
    const infoMsg = document.getElementById("info-msg")      as HTMLElement;
    const results = document.getElementById("results")       as HTMLElement;

    // modal close
    document.getElementById("modal-close")!.addEventListener("click", closeModal);
    document.getElementById("tx-modal")!.addEventListener("click", (e) => {
      if (e.target === e.currentTarget) closeModal();
    });
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && modalOpen) closeModal();
    });

    function setInfo(msg: string, isError = false) {
      infoMsg.textContent = msg;
      infoMsg.className   = "info-msg" + (isError ? " error" : "");
    }

    btn.addEventListener("click", async () => {
      const address = input.value.trim();

      if (!/^0x[0-9a-fA-F]{40}$/.test(address)) {
        setInfo("Enter a valid 0x Avalanche C-Chain address.", true);
        return;
      }

      btn.disabled  = true;
      btnText.textContent = "Analyzing...";
      results.classList.add("hidden");
      setInfo("fetching transactions from Glacier API...");

      try {
        const res  = await fetch("/api/anomaly", {
          method:  "POST",
          headers: { "Content-Type": "application/json" },
          body:    JSON.stringify({ address }),
        });

        const data = await res.json() as {
          transactions?: TxResult[];
          message?: string;
          error?: string;
        };

        if (!res.ok || data.error) {
          setInfo(data.error ?? "Something went wrong. Please try again.", true);
          return;
        }

        if (!data.transactions?.length) {
          setInfo(data.message ?? "No transactions found.", false);
          return;
        }

        setInfo(`${data.transactions.length} transactions analyzed. Click any row to inspect.`);
        renderResults(data.transactions);

      } catch {
        setInfo("Network error. Please try again.", true);
      } finally {
        btn.disabled = false;
        btnText.textContent = "Analyze";
      }
    });

    input.addEventListener("keydown", (e) => {
      if (e.key === "Enter") btn.click();
    });

    // magnetic button
    btn.addEventListener("mousemove", (e) => {
      const rect = btn.getBoundingClientRect();
      gsap.to(btn, {
        x: (e.clientX - rect.left - rect.width  / 2) * 0.35,
        y: (e.clientY - rect.top  - rect.height / 2) * 0.35,
        duration: 0.3, ease: "power2.out",
      });
    });
    btn.addEventListener("mouseleave", () => {
      gsap.to(btn, { x: 0, y: 0, duration: 0.5, ease: "elastic.out(1,0.5)" });
    });
  }

  document.addEventListener("astro:page-load", initAnomaly);
</script>
