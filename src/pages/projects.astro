---
import BaseLayout from "../layouts/BaseLayout.astro";

const projects = [
  {
    index: "01",
    title: "2D Snake Game",
    summary: "A basic 2D snake game made with o4 mini high.",
    detail: 'Just click "View Live" and try it yourself.',
    live: "/snake-game",
    source: "#",
  },
  {
    index: "02",
    title: "BTC Price in MYR",
    summary: "Figure out the current price of BTC in MYR.",
    detail: "Fetch API of exchange rate and BTC/USD pair, then convert.",
    live: "/crypto-api",
    source: "#",
  },
  {
    index: "03",
    title: "Avalanche Anomaly Detector",
    summary: "Paste a C-Chain wallet address and detect anomalous transactions using an Isolation Forest model.",
    detail: "Server-side ML on Avalanche C-Chain transaction data: value, gas, and timing patterns fed into an Isolation Forest to score and flag outliers.",
    live: "/anomaly-detector",
    source: "#",
  },
  {
    index: "04",
    title: "AI News Bot",
    summary: "A grok-powered agent that checks the internet daily, curates top AI news, and auto-posts to Instagram.",
    detail: "built on xAI Grok's web search API. runs on a daily cron schedule via Cloudflare Workers. live feed below.",
    live: "#instagram-feed",
    source: "#",
  },
  {
    index: "05",
    title: "Project Five",
    summary: "Nothing here yet. Stay tuned.",
    detail: "Details coming soon.",
    live: "#",
    source: "#",
  },
  {
    index: "06",
    title: "Project Six",
    summary: "Nothing here yet. Stay tuned.",
    detail: "Details coming soon.",
    live: "#",
    source: "#",
  },
];
---
<BaseLayout title="Gosvindraj | Projects">
  <section id="projects">
    <div class="projects-header">
      <p class="section-label" id="projects-label">Work</p>
      <h2 class="section-title" id="projects-title">Fun projects.</h2>
    </div>

    <div class="project-grid" id="project-grid">
      {projects.map((p) => (
        <div class="project-card" role="button" tabindex="0" aria-expanded="false">
          <span class="card-sheen"></span>
          <span class="card-index">{p.index}</span>
          <h3 class="card-title">{p.title}</h3>
          <p class="card-summary">{p.summary}</p>
          <div class="card-details">
            <p class="card-detail-text">{p.detail}</p>
            <div class="card-links">
              <a href={p.live} class="card-link">View Live <span>↗</span></a>
              <a href={p.source} class="card-link">Source <span>↗</span></a>
            </div>
          </div>
          <div class="card-indicator" aria-hidden="true">
            <i class="fa-solid fa-chevron-down"></i>
          </div>
        </div>
      ))}
    </div>
  </section>

  <section id="instagram-feed">
    <div class="insta-card-wrap">
      <div class="insta-header">
        <p class="section-label" id="insta-label">AI Daily Roundup</p>
        <div class="insta-profile-link">
          <i class="fa-brands fa-instagram"></i>
          <span>@agentgosh</span>
          <a href="https://www.instagram.com/agentgosh/" target="_blank" rel="noopener noreferrer" class="insta-follow-cta">Follow</a>
        </div>
      </div>
      <div class="insta-grid" id="insta-grid"></div>
    </div>
  </section>
</BaseLayout>

<style>
  #projects {
    min-height: calc(100vh - var(--nav-height));
    padding: 4rem 8% 6rem;
    max-width: 1400px;
    margin: 0 auto;
  }

  .projects-header {
    margin-bottom: 3rem;
  }

  .section-label {
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 0.5rem;
    opacity: 0;
  }

  .section-title {
    font-family: "Cormorant Garamond", serif;
    font-size: clamp(2rem, 5vw, 3.8rem);
    font-weight: 300;
    color: var(--text);
    letter-spacing: 0.03em;
    opacity: 0;
  }

  /* grid */
  .project-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1px;
    border: 1px solid var(--border);
    perspective: 1000px;
  }

  .project-card {
    background: var(--bg);
    padding: 2rem;
    border-right: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    position: relative;
    overflow: hidden;
    transition: background var(--transition);
    opacity: 0; /* GSAP controls */
    will-change: transform;
  }

  .project-card::before {
    content: '';
    position: absolute;
    inset: 0;
    border: 1px solid transparent;
    transition: border-color var(--transition);
    pointer-events: none;
    z-index: 1;
  }

  .project-card:hover { background: var(--surface); }
  .project-card:hover::before { border-color: var(--border-hover); }

  /* sheen highlight (moved by JS) */
  .card-sheen {
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at var(--mx, 50%) var(--my, 50%), rgba(155,109,206,0.07) 0%, transparent 60%);
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.3s ease;
    z-index: 0;
  }

  .project-card:hover .card-sheen { opacity: 1; }

  .card-index {
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.15em;
    color: var(--muted);
    font-family: "JetBrains Mono", monospace;
    position: relative;
    z-index: 2;
  }

  .card-title {
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--text);
    letter-spacing: 0.01em;
    position: relative;
    z-index: 2;
  }

  .card-summary {
    font-size: 0.85rem;
    color: var(--muted);
    line-height: 1.6;
    flex: 1;
    position: relative;
    z-index: 2;
  }

  .card-details {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.35s ease, opacity 0.35s ease;
    opacity: 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    position: relative;
    z-index: 2;
  }

  .project-card.active .card-details {
    max-height: 120px;
    opacity: 1;
  }

  .card-detail-text {
    font-size: 0.85rem;
    color: var(--muted);
    line-height: 1.6;
  }

  .card-links {
    display: flex;
    gap: 1.25rem;
  }

  .card-link {
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--muted);
    transition: color var(--transition);
    cursor: none;
  }

  .card-link span {
    display: inline-block;
    transition: transform var(--transition);
  }

  .card-link:hover { color: var(--accent); }
  .card-link:hover span { transform: translate(2px, -2px); }

  /* clickable card */
  .project-card { cursor: none; }

  .card-indicator {
    position: absolute;
    bottom: 0.9rem;
    right: 1rem;
    width: 22px;
    height: 22px;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--border);
    border-radius: 2px;
    color: var(--muted);
    font-size: 9px;
    z-index: 2;
    transition: opacity var(--transition), color var(--transition),
                border-color var(--transition), background var(--transition),
                transform 0.3s ease;
    /* hidden on desktop until hover */
    opacity: 0;
  }

  .project-card:hover .card-indicator {
    opacity: 1;
    color: var(--accent);
    border-color: var(--border-hover);
    background: var(--accent-dim);
  }

  .project-card.active .card-indicator {
    transform: rotate(180deg);
  }

  /* mobile: no hover available — always show indicator */
  @media (hover: none) {
    .card-indicator {
      opacity: 0.35;
      animation: indicator-bob 2.4s ease-in-out infinite;
    }

    .project-card.active .card-indicator {
      opacity: 0.6;
      animation: none;
    }
  }

  @keyframes indicator-bob {
    0%, 100% { transform: translateY(0); }
    50%       { transform: translateY(-3px); }
  }

  @media (max-width: 700px) {
    #projects { padding: 3rem 6% 4rem; }
    .project-grid { grid-template-columns: 1fr; }
  }

  /* ── Instagram feed ──────────────────────── */
  #instagram-feed {
    padding: 4rem 8% 6rem;
    max-width: 1400px;
    margin: 0 auto;
    border-top: 1px solid var(--border);
  }

  .insta-card-wrap {
    border-radius: 8px;
    padding: 2rem;
    background:
      linear-gradient(var(--surface), var(--surface)) padding-box,
      linear-gradient(135deg, rgba(155, 109, 206, 0.45), rgba(255, 255, 255, 0.04) 50%, rgba(0, 180, 220, 0.2)) border-box;
    border: 1px solid transparent;
    box-shadow: 0 12px 48px rgba(0, 0, 0, 0.35);
  }

  .insta-header {
    margin-bottom: 2rem;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 1rem;
  }

  .insta-profile-link {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    font-size: 1rem;
    font-weight: 400;
    letter-spacing: 0.03em;
    color: #9a9aaf;
    text-decoration: none;
    cursor: none;
    margin-top: 0.6rem;
  }

  .insta-profile-link i {
    font-size: 1.1rem;
    color: #c2185b;
  }

  .insta-follow-cta {
    padding: 4px 12px;
    border: 1px solid var(--border);
    border-radius: 2px;
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent);
    text-decoration: none;
    cursor: none;
    transition: background var(--transition), border-color var(--transition), color var(--transition);
  }

  .insta-follow-cta:hover {
    background: var(--accent-dim);
    border-color: var(--accent);
    color: var(--text);
  }

  .insta-desc {
    font-size: 0.85rem;
    color: var(--muted);
    line-height: 1.7;
    margin-top: 0.75rem;
  }

  .insta-grid {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
    border-radius: 6px;
    overflow: hidden;
    box-shadow: 0 0 0 1px var(--border), 0 8px 40px rgba(0, 0, 0, 0.4);
  }


  @media (max-width: 1100px) {
    .insta-grid { grid-template-columns: repeat(4, 1fr); }
  }

  @media (max-width: 700px) {
    #instagram-feed { padding: 3rem 6% 4rem; }
    .insta-grid { grid-template-columns: repeat(3, 1fr); }
  }
</style>

<style is:global>
  /* Instagram feed — dynamically inserted via JS, needs global scope */
  .insta-card {
    position: relative;
    overflow: hidden;
    display: block;
    background: var(--bg);
    border-right: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    opacity: 0;
    cursor: none;
    transition: background var(--transition);
  }

  .insta-card::before {
    content: '';
    position: absolute;
    inset: 0;
    border: 1px solid transparent;
    transition: border-color var(--transition);
    pointer-events: none;
    z-index: 2;
  }

  .insta-card:hover { background: var(--surface); }
  .insta-card:hover::before { border-color: var(--border-hover); }
  .insta-card:hover .card-sheen { opacity: 1; }
  .insta-card:hover .insta-thumb img { transform: scale(1.04); }
  .insta-card:hover .insta-overlay { opacity: 1; }

  .insta-thumb {
    position: relative;
    width: 100%;
    padding-bottom: 100%;
    overflow: hidden;
  }

  .insta-thumb img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
  }

  .insta-overlay {
    position: absolute;
    inset: 0;
    background: rgba(11, 11, 13, 0.3);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.4rem;
    opacity: 1;
    transition: background var(--transition);
    z-index: 1;
  }

  .insta-view,
  .insta-type-badge {
    opacity: 0;
    transition: opacity var(--transition);
  }

  .insta-card:hover .insta-overlay {
    background: rgba(11, 11, 13, 0.72);
  }

  .insta-card:hover .insta-view,
  .insta-card:hover .insta-type-badge {
    opacity: 1;
  }

  .insta-ig-icon {
    position: absolute;
    top: 0.55rem;
    right: 0.6rem;
    font-size: 13px;
    color: var(--muted);
    opacity: 0.45;
    z-index: 3;
    transition: opacity var(--transition), color var(--transition);
    pointer-events: none;
  }

  .insta-card:hover .insta-ig-icon {
    opacity: 0;
  }

  .insta-view {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--text);
  }

  .insta-view i {
    font-size: 13px;
  }

  .insta-type-badge {
    font-size: 10px;
    font-family: "JetBrains Mono", monospace;
    color: var(--accent);
    letter-spacing: 0.08em;
  }

  .insta-status {
    grid-column: 1 / -1;
    padding: 3rem;
    text-align: center;
    font-size: 0.8rem;
    color: var(--muted);
    font-family: "JetBrains Mono", monospace;
    letter-spacing: 0.1em;
  }
</style>

<script>
  import gsap from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  import { ScrollToPlugin }  from "gsap/ScrollToPlugin";
  gsap.registerPlugin(ScrollTrigger, ScrollToPlugin);

  const GLITCH = "!<>-_\\/[]{}—=+*^?#@$%&";

  function glitchReveal(el: HTMLElement, finalText: string, duration = 780) {
    const frames = 18;
    const ms = Math.round(duration / frames);
    let frame = 0;
    el.style.opacity = "1";

    const iv = setInterval(() => {
      const progress = frame / frames;
      const revealed = Math.floor(progress * finalText.length);

      let display = "";
      for (let i = 0; i < finalText.length; i++) {
        if (i < revealed) {
          display += Math.random() < 0.07 * (1 - progress)
            ? GLITCH[Math.floor(Math.random() * GLITCH.length)]
            : finalText[i];
        } else {
          display += finalText[i] === " " ? "\u00a0"
            : GLITCH[Math.floor(Math.random() * GLITCH.length)];
        }
      }
      el.textContent = display;

      if (frame < frames - 2 && Math.random() < 0.4) {
        el.style.textShadow = `${+(Math.random()*4-2).toFixed(1)}px 0 rgba(255,0,200,0.6),`
                            + `${+(Math.random()*-4+2).toFixed(1)}px 0 rgba(0,255,255,0.6)`;
      } else {
        el.style.textShadow = "";
      }

      frame++;
      if (frame > frames) {
        clearInterval(iv);
        el.textContent      = finalText;
        el.style.textShadow = "";
      }
    }, ms);
  }

  function initProjects() {
    const label = document.getElementById("projects-label");
    const title = document.getElementById("projects-title");
    const cards = document.querySelectorAll<HTMLElement>(".project-card");
    if (!label || !cards.length) return;

    const titleText = title?.textContent ?? "Fun projects.";

    /* ── Header reveal ───────────────────────── */
    ScrollTrigger.create({
      trigger: label,
      start: "top 85%",
      once: true,
      onEnter: () => {
        gsap.fromTo(label, { opacity: 0, x: -16 }, { opacity: 1, x: 0, duration: 0.5, ease: "power3.out" });
        if (title) {
          setTimeout(() => glitchReveal(title, titleText, 780), 150);
        }
      },
    });

    /* ── Card scroll reveals ─────────────────── */
    gsap.fromTo(
      cards,
      { opacity: 0, y: 40, scale: 0.97 },
      {
        opacity: 1,
        y: 0,
        scale: 1,
        stagger: { amount: 0.45, from: "start" },
        duration: 0.6,
        ease: "power3.out",
        scrollTrigger: {
          trigger: "#project-grid",
          start: "top 80%",
          once: true,
        },
      }
    );

    /* ── Card 3D tilt + sheen ────────────────── */
    cards.forEach((card) => {
      const sheen = card.querySelector<HTMLElement>(".card-sheen");

      card.addEventListener("mousemove", (e) => {
        const rect = card.getBoundingClientRect();
        const rx = ((e.clientY - rect.top)  / rect.height - 0.5) * 10;
        const ry = ((e.clientX - rect.left) / rect.width  - 0.5) * -10;

        gsap.to(card, {
          rotationX: rx,
          rotationY: ry,
          duration: 0.4,
          ease: "power2.out",
          transformPerspective: 800,
        });

        if (sheen) {
          const mx = ((e.clientX - rect.left) / rect.width)  * 100;
          const my = ((e.clientY - rect.top)  / rect.height) * 100;
          sheen.style.setProperty("--mx", mx + "%");
          sheen.style.setProperty("--my", my + "%");
        }
      });

      card.addEventListener("mouseleave", () => {
        gsap.to(card, {
          rotationX: 0,
          rotationY: 0,
          duration: 0.6,
          ease: "elastic.out(1, 0.6)",
          transformPerspective: 800,
        });
      });
    });

    /* ── Card toggle (full card click) ──────────── */
    cards.forEach((card) => {
      // stop link clicks from toggling the card; smooth-scroll hash links
      card.querySelectorAll("a").forEach(a => a.addEventListener("click", e => {
        e.stopPropagation();
        const href = a.getAttribute("href") ?? "";
        if (href.startsWith("#") && href.length > 1) {
          e.preventDefault();
          const target = document.querySelector(href);
          if (target) gsap.to(window, { scrollTo: { y: target, offsetY: 80 }, duration: 0.9, ease: "power3.inOut" });
        }
      }));

      function handleCardActivate() {
        const isNowActive = card.classList.toggle("active");
        card.setAttribute("aria-expanded", String(isNowActive));
      }

      card.addEventListener("click", handleCardActivate);

      card.addEventListener("keydown", (e: KeyboardEvent) => {
        if (e.key === "Enter" || e.key === " ") {
          e.preventDefault();
          handleCardActivate();
        }
      });
    });
  }

  interface InstaPost {
    id: string;
    caption: string;
    media_type: "IMAGE" | "VIDEO" | "CAROUSEL_ALBUM";
    media_url: string;
    thumbnail_url?: string;
    permalink: string;
    timestamp: string;
  }

  async function initInstagramFeed() {
    const grid  = document.getElementById("insta-grid");
    const label = document.getElementById("insta-label");
    if (!grid) return;

    if (label) {
      ScrollTrigger.create({
        trigger: label,
        start: "top 85%",
        once: true,
        onEnter: () => {
          gsap.fromTo(label, { opacity: 0, x: -16 }, { opacity: 1, x: 0, duration: 0.5, ease: "power3.out" });
        },
      });
    }

    grid.innerHTML = `<p class="insta-status">loading feed…</p>`;

    try {
      const res  = await fetch("https://marketing-automation-api.gosvind.workers.dev/api/public/instagram-feed");
      if (!res.ok) throw new Error("api error");
      const data = await res.json() as { posts: InstaPost[] };
      const posts = (data.posts ?? []).slice(0, 12);

      if (!posts.length) {
        grid.innerHTML = `<p class="insta-status">no posts yet.</p>`;
        return;
      }

      grid.innerHTML = posts.map((post) => {
        const src     = post.media_type === "VIDEO" ? (post.thumbnail_url ?? "") : post.media_url;
        const badge   = post.media_type === "VIDEO"
          ? `<span class="insta-type-badge">▶ video</span>`
          : "";
        return `<a href="${post.permalink}" target="_blank" rel="noopener noreferrer" class="insta-card" aria-label="View post on Instagram">
          <span class="card-sheen"></span>
          <span class="insta-ig-icon"><i class="fa-brands fa-instagram"></i></span>
          <div class="insta-thumb">
            <img src="${src}" alt="" loading="lazy">
            <div class="insta-overlay">${badge}<span class="insta-view"><i class="fa-brands fa-instagram"></i> View on IG ↗</span></div>
          </div>
        </a>`;
      }).join("");

      const cards = grid.querySelectorAll<HTMLElement>(".insta-card");

      gsap.fromTo(cards,
        { opacity: 0, y: 30, scale: 0.97 },
        {
          opacity: 1, y: 0, scale: 1,
          stagger: { amount: 0.5, from: "start" },
          duration: 0.55,
          ease: "power3.out",
          scrollTrigger: { trigger: grid, start: "top 85%", once: true },
        }
      );

      cards.forEach((card) => {
        const sheen = card.querySelector<HTMLElement>(".card-sheen");
        card.addEventListener("mousemove", (e) => {
          const rect = card.getBoundingClientRect();
          if (sheen) {
            sheen.style.setProperty("--mx", ((e.clientX - rect.left) / rect.width  * 100) + "%");
            sheen.style.setProperty("--my", ((e.clientY - rect.top)  / rect.height * 100) + "%");
          }
        });
      });

    } catch {
      grid.innerHTML = `<p class="insta-status">couldn't load feed.</p>`;
    }
  }

  document.addEventListener("astro:page-load", initProjects);
  document.addEventListener("astro:page-load", initInstagramFeed);
</script>
